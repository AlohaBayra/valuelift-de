---
import Base from "../layouts/Base.astro";
import AngelWriteDemo from "../components/AngelWriteDemo.astro";

// ─── Zentrale Konstanten (Fragenkatalog v2, 2026-06-10) ──────────────────────
const TIDYCAL =
  "https://tidycal.com/marcuseichler/kennenlerngesprach-mit-marcus-eichler-1wr7yd6";
const SIGNUP_URL =
  "https://angelwrite-server-production.up.railway.app/leadmagnet/signup";
const FACTORS = { content: 0.60, recherche: 0.50, angebote: 0.40, admin: 0.30, kundenkomm: 0.25 };
const WEEKS = 46;
const HRS_PER_WEEK = 40;
const HRS_PER_DAY = 8;
const FB_STUNDEN = 5;
const FB_SATZ = 1400;

const STEPS = [
  { type: "intro" },
  {
    type: "choice", key: "schmerz", q: "Was raubt dir als Interim Manager gerade am meisten Energie?", opts: [
      { l: "Sichtbar bleiben, während ich im Mandat stecke — fachlich liefere ich, aber für Akquise bleibt keine Zeit.", v: "akquise" },
      { l: "Mein nächstes Mandat hängt komplett an mir — kein System, das im Hintergrund weiterläuft.", v: "allein" },
      { l: "Ich bin voll im Mandat — und verdränge, dass danach wieder Funkstille droht.", v: "lost" },
      { l: "Liefern, dokumentieren, akquirieren gleichzeitig — das ständige Umschalten zerreißt mich.", v: "rollen" },
    ],
  },
  {
    type: "choice", key: "aufgabe", q: "Und welche Aufgabe rund um dein nächstes Mandat frisst am meisten Zeit — die du am liebsten nie wieder selbst machen würdest?", opts: [
      { l: "Sichtbarkeit & LinkedIn-Präsenz", v: "content" },
      { l: "Markt-/Auftraggeber-Recherche & Vorbereitung", v: "recherche" },
      { l: "Angebote, Exposés & Akquise-Mails", v: "angebote" },
      { l: "Reporting, Doku & Mandats-Admin", v: "admin" },
      { l: "Netzwerk pflegen & Provider-Kontakte", v: "kundenkomm" },
    ],
  },
  { type: "num", key: "stunden", q: "Wie viele Stunden pro Woche verschluckt das — Zeit, die eigentlich ins Mandat, ins nächste Mandat oder zu dir selbst gehört?", ph: "5", unit: "Std/Woche" },
  { type: "num", key: "stundensatz", q: "Was ist dein Tagessatz im Mandat — grob?", ph: "1400", unit: "€/Tag", hint: "Grobe Schätzung reicht — es geht ums Größenverhältnis, nicht um die Buchhaltung." },
  {
    type: "choice", key: "ki_status", q: "Wo stehst du mit KI gerade — ehrlich?", opts: [
      { l: "Noch gar nicht — im Mandat fehlt mir die Zeit, mich einzuarbeiten.", v: "start" },
      { l: "Viel ausprobiert (ChatGPT, Tools), aber nichts läuft dauerhaft neben dem Mandat.", v: "probiert" },
      { l: "Erste Dinge laufen, aber kein System, das mich während des Mandats sichtbar hält.", v: "system" },
    ],
  },
  {
    type: "choice", key: "ziel", q: "Wenn dir das nächste Mandat sicher wäre — was käme zuerst?", opts: [
      { l: "Endlich planbar Anschlussmandate — ohne Leerlauf dazwischen.", v: "kunden" },
      { l: "Mal wieder durchatmen — ohne Akquise-Druck im Nacken.", v: "durchatmen" },
      { l: "Mich aufs Mandat konzentrieren statt nebenbei Akquise zu jonglieren.", v: "strategie" },
      { l: "Wieder Mandate, die wirklich zu mir passen.", v: "freude" },
    ],
  },
  { type: "gate" },
  { type: "result" },
];

const OPEN = {
  akquise: "Dein Engpass ist nicht dein Können. Es ist das Akquise-Paradox: Im Mandat hast du keine Zeit für Sichtbarkeit — und genau das rächt sich in der Lücke danach. Dieser Teil lässt sich systematisieren, ohne dass du ihn selbst machst.",
  allein: "Das Problem ist nicht, dass du zu wenig tust. Es ist, dass dein nächstes Mandat allein an dir hängt — und niemand im Hintergrund deine Sichtbarkeit am Laufen hält.",
  lost: "Du arbeitest nicht zu wenig. Du verdrängst nur, dass nach dem Mandat die Funkstille kommt — und genau das kostet dich am meisten.",
  rollen: "Die meiste Energie verlierst du nicht im Liefern, sondern im ständigen Umschalten zwischen Mandat, Doku und Akquise.",
};

const KISTAT = {
  start: "Du musst nicht zum KI-Experten werden. Du brauchst ein System, das dich während des Mandats sichtbar hält — und jemanden, der es mit dir aufsetzt.",
  probiert: "Und du hast längst genug ausprobiert. Es hakt nicht am Wissen — es hakt daran, dass neben dem Mandat niemand den ersten Prozess mit dir fertig baut.",
  system: "Du bist weiter als die meisten. Jetzt geht es darum, aus Einzelteilen ein System zu machen, das dein nächstes Mandat anbahnt, während du lieferst.",
};

const PLAN = {
  content: ["Ein Prompt-System für deine 5 Kernthemen als Interim-Profil", "Eine Vorlage „Mandats-Learning → Post → erster Kommentar“", "Ein fester 30-Minuten-Slot pro Woche, in dem die KI 80 % vorschreibt"],
  recherche: ["Eine KI-Routine, die Auftraggeber und Provider vorsortiert", "Auto-Zusammenfassung der Branchen-/Mandatslage in dein Format", "Ein wiederverwendbares Recherche-Template statt leerem Blatt"],
  angebote: ["KI-Entwurf für Exposé/Angebot aus 3 Stichpunkten", "Angebots-Vorlage je Mandatstyp mit dynamischen Bausteinen", "Automatisierte Nachfass-Mails an warme Provider"],
  admin: ["Mandats-Reporting als KI-Entwurf statt Handarbeit", "Anonymisierte Erfolgs-Doku als Beleg für dein nächstes Mandat", "Ein einfaches Pipeline-Board statt Zettelwirtschaft"],
  kundenkomm: ["Antwort-Vorlagen für Provider- und Netzwerk-Fragen", "Touchpoint-Erinnerungen 6–8 Wochen vor Mandatsende", "Eine Warmhalte-Sequenz fürs Netzwerk — ohne Spam"],
};
---

<Base
  title="Interim-Akquise-Check — was kostet dich die Lücke zwischen den Mandaten? | Value Lift AI"
  description="In 2 Minuten: Wie viel dich das Akquise-Paradox kostet — Sichtbarkeit, die im Mandat fehlt, und der Leerlauf danach. Plus dein erster Schritt. Kein Login, kein Pitch."
  path="/check"
  hideNav={true}
>
  <section class="vlc-wrap">
    <div class="vlc-shell">
      <div class="vlc-card" id="vlc-card"></div>
      <!-- AngelWrite-Demo wird im Ergebnis (nur macOS) in die Geschenk-Zeile verschoben -->
      <div id="vlc-demo-holder" style="display:none"><AngelWriteDemo /></div>
    </div>
  </section>
</Base>

<style is:global>
  .vlc-wrap { font-family: "Inter", system-ui, -apple-system, sans-serif;
    background: radial-gradient(1100px 560px at 50% -10%, #13294a 0%, #0B1528 58%);
    color: #fff; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 32px 18px 56px; }
  .vlc-shell { width: 100%; max-width: 540px; }
  .vlc-card { background: #10203b; border: 1px solid #20335a; border-radius: 20px; padding: 30px;
    box-shadow: 0 24px 70px rgba(0,0,0,.45); }
  @media (max-width: 480px) { .vlc-card { padding: 22px 18px; } }

  .vlc-progress { height: 6px; background: #1c2c4a; border-radius: 6px; margin-bottom: 22px; overflow: hidden; }
  .vlc-progress > i { display: block; height: 100%; background: #F5A623; width: 0; transition: width .35s ease; }
  .vlc-eyebrow { font-size: 12px; letter-spacing: .05em; color: #94a3b8; margin-bottom: 10px; }
  .vlc-h { font-family: "Outfit", "Inter", sans-serif; font-size: 24px; font-weight: 800; line-height: 1.24; margin: 0 0 10px; letter-spacing: -.01em; }
  .vlc-q { font-family: "Outfit", "Inter", sans-serif; font-size: 21px; font-weight: 800; line-height: 1.3; margin: 0 0 22px; letter-spacing: -.01em; }
  .vlc-sub { color: #c7d2e0; font-size: 15px; line-height: 1.55; margin: 0 0 24px; }

  .vlc-opt { display: block; width: 100%; text-align: left; background: #152743; color: #fff; border: 1px solid #284069;
    border-radius: 13px; padding: 15px 16px; margin-bottom: 11px; font-size: 15.5px; line-height: 1.4; cursor: pointer;
    transition: .15s; font-family: inherit; }
  .vlc-opt:hover { border-color: #F5A623; background: #1a2f52; transform: translateY(-1px); }

  .vlc-field { display: flex; align-items: center; gap: 12px; background: #152743; border: 1px solid #284069;
    border-radius: 13px; padding: 6px 6px 6px 16px; margin-bottom: 8px; }
  .vlc-field input { flex: 1; background: transparent; border: 0; outline: 0; color: #fff; font-size: 26px; font-weight: 700; font-family: inherit; width: 100%; }
  .vlc-field input::placeholder { color: #4d6488; }
  .vlc-unit { color: #94a3b8; font-size: 15px; font-weight: 600; padding-right: 8px; white-space: nowrap; }
  .vlc-hint { color: #94a3b8; font-size: 13px; margin: 0 0 18px; }

  .vlc-in { width: 100%; background: #152743; border: 1px solid #284069; border-radius: 13px; padding: 14px 16px;
    color: #fff; font-size: 16px; font-family: inherit; margin-bottom: 11px; outline: 0; }
  .vlc-in:focus { border-color: #F5A623; }
  .vlc-in::placeholder { color: #4d6488; }

  .vlc-btn { display: block; width: 100%; text-align: center; background: #F5A623; color: #0B1528; border: 0;
    border-radius: 13px; padding: 15px 18px; font-size: 16px; font-weight: 800; cursor: pointer; font-family: inherit;
    text-decoration: none; transition: .15s; }
  .vlc-btn:hover { filter: brightness(1.06); transform: translateY(-1px); }
  .vlc-btn[disabled] { opacity: .6; cursor: default; transform: none; filter: none; }

  .vlc-skip { display: block; width: 100%; text-align: center; background: none; border: 0; color: #94a3b8;
    font-size: 13px; cursor: pointer; font-family: inherit; padding: 10px 4px 0; }
  .vlc-skip:hover { color: #fff; }

  .vlc-check { display: flex; gap: 9px; align-items: flex-start; color: #94a3b8; font-size: 12.5px; line-height: 1.45; margin: 4px 0 18px; }
  .vlc-check input { margin-top: 2px; }
  .vlc-check a { color: #F5A623; }
  .vlc-err { color: #fca5a5; font-size: 13.5px; font-weight: 600; margin: 0 0 12px; }

  .vlc-res-label { font-size: 12px; letter-spacing: .08em; text-transform: uppercase; color: #94a3b8; margin-bottom: 12px; }
  .vlc-open { font-family: "Outfit", "Inter", sans-serif; font-size: 18.5px; font-weight: 700; line-height: 1.4; margin: 0 0 12px; }
  .vlc-kistat { color: #c7d2e0; font-size: 15px; line-height: 1.5; margin: 0 0 20px; }
  .vlc-money { font-size: 16px; line-height: 1.55; color: #dbe4f0; margin: 0 0 4px; }
  .vlc-money b { color: #fff; }
  .vlc-bighours { font-family: "Outfit", "Inter", sans-serif; font-size: 30px; font-weight: 800; color: #F5A623; line-height: 1.1; }
  .vlc-money-sub { color: #94a3b8; font-size: 13.5px; line-height: 1.5; margin: 0 0 22px; }

  .vlc-plan { background: #0d1c34; border: 1px solid #21345b; border-radius: 14px; padding: 18px 18px 6px; margin: 0 0 18px; }
  .vlc-plan h4 { margin: 0 0 12px; font-size: 14px; letter-spacing: .02em; color: #F5A623; }
  .vlc-plan ul { margin: 0; padding: 0; list-style: none; }
  .vlc-plan li { position: relative; padding: 0 0 12px 26px; font-size: 14.5px; line-height: 1.45; color: #dbe4f0; }
  .vlc-plan li:before { content: "\2192"; position: absolute; left: 0; top: 0; color: #F5A623; font-weight: 800; }

  .vlc-gift { display: flex; gap: 13px; align-items: flex-start; background: #171a12; border: 1px solid #3a3413;
    border-radius: 14px; padding: 15px 16px; margin: 0 0 16px; }
  .vlc-gift.win { background: #101d18; border-color: #1f4036; }
  .vlc-gift .g-anchor { font-size: 12px; color: #F5A623; font-weight: 800; white-space: nowrap; border: 1px solid #5a4a16;
    border-radius: 8px; padding: 3px 7px; align-self: center; }
  .vlc-gift.win .g-anchor { color: #5dcaa5; border-color: #1f4036; }
  .vlc-gift p { margin: 0; font-size: 13.5px; line-height: 1.45; color: #e7ddc2; }
  .vlc-gift.win p { color: #cfe7dd; }
  #vlc-demo-slot { margin: 0 0 20px; }

  .vlc-cta-note { text-align: center; color: #94a3b8; font-size: 12.5px; line-height: 1.5; margin: 11px 0 0; }
  .vlc-tiny { color: #5e7196; font-size: 12px; text-align: center; line-height: 1.5; margin: 20px 0 0; }
  .vlc-back { display: block; margin: 14px auto 0; background: none; border: 0; color: #94a3b8; font-size: 13px; cursor: pointer; font-family: inherit; padding: 4px; }
  .vlc-back:hover { color: #fff; }

  .vlc-rolle { border-top: 1px solid #21345b; margin-top: 22px; padding-top: 18px; }
  .vlc-rolle-lbl { display: block; color: #94a3b8; font-size: 13px; line-height: 1.45; margin-bottom: 10px; }
  .vlc-rolle-row { display: flex; gap: 8px; align-items: stretch; }
  .vlc-rolle-row .vlc-in { margin-bottom: 0; }
  .vlc-rolle-save { background: #152743; color: #fff; border: 1px solid #284069; border-radius: 13px; padding: 0 16px;
    font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; white-space: nowrap; }
  .vlc-rolle-save:hover { border-color: #F5A623; }
</style>

<script is:inline define:vars={{ FACTORS, WEEKS, HRS_PER_WEEK, HRS_PER_DAY, FB_STUNDEN, FB_SATZ, TIDYCAL, SIGNUP_URL, STEPS, OPEN, KISTAT, PLAN }}>
  (function () {
    var IS_MAC = /Mac/.test(navigator.platform) || /Macintosh/.test(navigator.userAgent);
    var state = { stunden: FB_STUNDEN, stundensatz: FB_SATZ };
    var idx = 0;
    var card = document.getElementById("vlc-card");

    function labelFor(key, val) {
      for (var i = 0; i < STEPS.length; i++) {
        if (STEPS[i].key === key && STEPS[i].opts) {
          for (var j = 0; j < STEPS[i].opts.length; j++) {
            if (STEPS[i].opts[j].v === val) return STEPS[i].opts[j].l;
          }
        }
      }
      return "";
    }
    function progress() {
      var q = (idx >= 1 && idx <= 6) ? idx : (idx > 6 ? 6 : 0);
      return '<div class="vlc-progress"><i style="width:' + (q / 6 * 100) + '%"></i></div>';
    }
    function go(n) { idx = n; render(); window.scrollTo({ top: 0, behavior: "smooth" }); }

    function render() {
      var s = STEPS[idx];

      if (s.type === "intro") {
        card.innerHTML =
          '<h1 class="vlc-h">Im Mandat keine Zeit für Sichtbarkeit. Danach Funkstille. Rechne in 2 Minuten aus, was dich diese Lücke jedes Jahr kostet — und sieh deinen ersten Schritt raus.</h1>' +
          '<p class="vlc-sub">Kein Login, kein Pitch. Ehrliche Selbsteinschätzung — von einem, der selbst im Mandat steht. Kein Berater-Sprech.</p>' +
          '<button class="vlc-btn" id="vlc-start">Check starten →</button>';
        document.getElementById("vlc-start").onclick = function () { go(1); };
        return;
      }

      if (s.type === "choice") {
        var h = progress() + '<div class="vlc-eyebrow">Frage ' + idx + ' von 6</div><div class="vlc-q">' + s.q + "</div>";
        s.opts.forEach(function (o) { h += '<button class="vlc-opt" data-v="' + o.v + '">' + o.l + "</button>"; });
        if (idx > 1) h += '<button class="vlc-back">← zurück</button>';
        card.innerHTML = h;
        Array.prototype.forEach.call(card.querySelectorAll(".vlc-opt"), function (b) {
          b.onclick = function () {
            state[s.key] = b.getAttribute("data-v");
            if (s.key === "aufgabe") state.faktor = FACTORS[state.aufgabe];
            go(idx + 1);
          };
        });
        var bk = card.querySelector(".vlc-back"); if (bk) bk.onclick = function () { go(idx - 1); };
        return;
      }

      if (s.type === "num") {
        card.innerHTML = progress() + '<div class="vlc-eyebrow">Frage ' + idx + ' von 6</div><div class="vlc-q">' + s.q + "</div>" +
          '<div class="vlc-field"><input id="vlc-num" type="number" inputmode="numeric" placeholder="' + s.ph + '" value="' + (state[s.key] != null ? state[s.key] : "") + '"><span class="vlc-unit">' + s.unit + "</span></div>" +
          (s.hint ? '<p class="vlc-hint">' + s.hint + "</p>" : '<div style="height:14px"></div>') +
          '<button class="vlc-btn" id="vlc-next">Weiter →</button>' +
          '<button class="vlc-skip" id="vlc-skip">Weiß ich nicht — mit Schätzwert ' + s.ph + ' weiter</button>' +
          '<button class="vlc-back">← zurück</button>';
        var inp = document.getElementById("vlc-num");
        function nxt() { var v = parseFloat(inp.value); state[s.key] = (isNaN(v) || v <= 0) ? parseFloat(s.ph) : v; go(idx + 1); }
        document.getElementById("vlc-next").onclick = nxt;
        document.getElementById("vlc-skip").onclick = function () { state[s.key] = parseFloat(s.ph); go(idx + 1); };
        inp.onkeydown = function (e) { if (e.key === "Enter") nxt(); };
        inp.focus();
        card.querySelector(".vlc-back").onclick = function () { go(idx - 1); };
        return;
      }

      if (s.type === "gate") {
        card.innerHTML = progress() +
          '<div class="vlc-eyebrow">Fast geschafft</div>' +
          '<div class="vlc-q">Deine Auswertung ist fertig.</div>' +
          '<p class="vlc-sub" style="margin-bottom:18px">Wohin soll deine Auswertung gehen? Dann siehst du sie sofort.</p>' +
          '<input class="vlc-in" id="g-vor" placeholder="Vorname" autocomplete="given-name">' +
          '<input class="vlc-in" id="g-mail" type="email" placeholder="E-Mail" autocomplete="email">' +
          '<input class="vlc-in" id="g-tel" placeholder="Telefon (optional)" autocomplete="tel">' +
          '<label class="vlc-check"><input type="checkbox" id="g-ok"><span>Ich möchte meine Auswertung per E-Mail erhalten und bin einverstanden, gelegentlich hilfreiche Impulse zu bekommen (jederzeit abbestellbar). Es gilt die <a href="/datenschutz" target="_blank" rel="noopener">Datenschutzerklärung</a>.</span></label>' +
          '<p class="vlc-err" id="g-err" style="display:none"></p>' +
          '<button class="vlc-btn" id="g-go">Ergebnis ansehen →</button>' +
          '<button class="vlc-back">← zurück</button>';

        var errEl = document.getElementById("g-err");
        function gerr(m) { errEl.textContent = m; errEl.style.display = "block"; }

        document.getElementById("g-go").onclick = function () {
          errEl.style.display = "none";
          var v = document.getElementById("g-vor").value.trim();
          var m = document.getElementById("g-mail").value.trim();
          var tel = document.getElementById("g-tel").value.trim();
          var ok = document.getElementById("g-ok").checked;
          if (!v) return gerr("Bitte gib deinen Vornamen ein.");
          if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(m)) return gerr("Bitte gib eine gültige E-Mail-Adresse ein.");
          if (!ok) return gerr("Bitte setze kurz das Häkchen — dann kommt die Auswertung sofort.");

          state.vorname = v; state.email = m; state.telefon = tel;
          var wk = state.stunden * (state.faktor || 0.5);
          var yr = Math.round(wk * WEEKS);
          var eur = Math.round(yr * (state.stundensatz / HRS_PER_DAY));
          var aufgabeLabel = labelFor("aufgabe", state.aufgabe);

          var payload = {
            vorname: v, email: m, telefon: tel,
            schmerz: state.schmerz, aufgabe: state.aufgabe,
            stunden: state.stunden, stundensatz: state.stundensatz,
            ki_status: state.ki_status, ziel: state.ziel, macos: IS_MAC,
            resultSummary: { stdJahr: yr, eurJahr: eur, topListe: aufgabeLabel, prioTitel: aufgabeLabel },
          };

          var btn = this; btn.disabled = true; btn.textContent = "Wird gesendet …";
          fetch(SIGNUP_URL, {
            method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload),
          })
            .then(function (r) { return r.json().catch(function () { return {}; }).then(function (d) { return { ok: r.ok && d.ok, d: d }; }); })
            .then(function (res) {
              if (res.ok) { go(idx + 1); }
              else { gerr((res.d && res.d.error) || "Konnte gerade nicht senden. Bitte versuche es erneut."); btn.disabled = false; btn.textContent = "Ergebnis ansehen →"; }
            })
            .catch(function () { gerr("Verbindung fehlgeschlagen. Bitte versuche es erneut."); btn.disabled = false; btn.textContent = "Ergebnis ansehen →"; });
        };
        card.querySelector(".vlc-back").onclick = function () { go(idx - 1); };
        return;
      }

      if (s.type === "result") {
        var wk = state.stunden * (state.faktor || 0.5);
        var wkR = Math.round(wk * 10) / 10;
        var yr = Math.round(wk * WEEKS);
        var wochen = Math.max(1, Math.round(yr / HRS_PER_WEEK));
        var eur = Math.round(yr * (state.stundensatz / HRS_PER_DAY));
        var eurF = eur.toLocaleString("de-DE");
        var plan = PLAN[state.aufgabe] || PLAN.content;
        var open = OPEN[state.schmerz] || OPEN.lost;
        var kistat = KISTAT[state.ki_status] || "";

        var h = '<div class="vlc-res-label">Deine Auswertung, ' + (state.vorname || "") + "</div>" +
          '<p class="vlc-open">' + open + "</p>" +
          (kistat ? '<p class="vlc-kistat">' + kistat + "</p>" : "") +
          '<p class="vlc-money">Du verlierst aktuell rund <b>' + wkR + ' Std./Woche</b> an dieser Aufgabe — das sind</p>' +
          '<div class="vlc-bighours">~' + yr + ' Stunden im Jahr</div>' +
          '<p class="vlc-money" style="margin-top:6px">mehr als <b>' + wochen + ' volle Arbeitswochen</b>, die nicht dir gehören.</p>' +
          '<p class="vlc-money-sub">Gegengerechnet mit deinem Tagessatz entspricht das rund ' + eurF + ' € im Jahr.</p>' +
          '<div class="vlc-plan"><h4>Dein erster Schritt</h4><ul>' +
          plan.map(function (p) { return "<li>" + p + "</li>"; }).join("") +
          "</ul></div>";

        if (IS_MAC) {
          h += '<div class="vlc-gift"><span class="g-anchor">19 € → 0 €</span><p><b>Bonus für Mac:</b> AngelWrite Free — diktier dein Mandats-Reporting, statt es zu tippen, die KI macht den Rest. Hab ich selbst in einer Woche mit KI gebaut. Genau solche Workflows baust du dir auch — ich zeig dir wie.</p></div>' +
            '<div id="vlc-demo-slot"></div>';
        } else {
          h += '<div class="vlc-gift win"><span class="g-anchor">Gratis</span><p><b>Dein Mini-Bauplan zum Mitnehmen:</b> Ich schicke dir die 3 Schritte oben als kompakte Vorlage per Mail — für dein nächstes Mandat sofort umsetzbar, ohne Vorkenntnisse.</p></div>';
        }

        h += '<a class="vlc-btn" href="' + TIDYCAL + '" target="_blank" rel="noopener">Kostenloses Erstgespräch buchen</a>' +
          '<p class="vlc-cta-note">30 Min per Video, von einem, der selbst im Mandat steht. Du gehst mit einem konkreten ersten Schritt raus — kein Pitch, kein Druck. Mein Modell: Ich verdiene erst, wenn dein nächstes Mandat steht. Das Risiko trage ich, nicht du.</p>' +
          '<p class="vlc-tiny">Ich habe dir gerade eine Bestätigungsmail geschickt. Bestätige sie kurz — dann bekommst du die Auswertung per Mail' + (IS_MAC ? ' und schaltest dein AngelWrite-Geschenk frei' : '') + '.</p>' +
          '<div class="vlc-rolle">' +
          '<label class="vlc-rolle-lbl" for="r-rolle">Optional: Was machst du beruflich? Hilft mir, dein Erstgespräch vorzubereiten.</label>' +
          '<div class="vlc-rolle-row"><input class="vlc-in" id="r-rolle" placeholder="z. B. Interim COO, Operations-Manager, Head of Operations"><button class="vlc-rolle-save" id="r-save">Senden</button></div>' +
          '<p class="vlc-hint" id="r-thanks" style="display:none;margin:8px 0 0">Danke — notiert. ✓</p>' +
          "</div>";

        card.innerHTML = h;

        if (IS_MAC) {
          var holder = document.getElementById("vlc-demo-holder");
          var slot = document.getElementById("vlc-demo-slot");
          if (holder && slot) { holder.style.display = ""; slot.appendChild(holder); }
        }

        var rsave = document.getElementById("r-save");
        if (rsave) rsave.onclick = function () {
          var rolle = document.getElementById("r-rolle").value.trim();
          if (!rolle) return;
          rsave.disabled = true;
          fetch(SIGNUP_URL, {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email: state.email, rolle: rolle, updateOnly: true }),
          }).then(function () {
            document.getElementById("r-thanks").style.display = "block";
            document.getElementById("r-rolle").disabled = true;
          }).catch(function () { rsave.disabled = false; });
        };
        return;
      }
    }

    render();
  })();
</script>
