---
import Base from "../layouts/Base.astro";

// AD-01 — Landingpage „KI-Kickstart" (97 € Festpreis · 2h · Live · Gruppe max. 15).
// Direktkauf via Stripe. Geld-zurück-Garantie auf die Session (keine Prozess-/Erfolgs-Garantie).
const stripeUrl = "https://buy.stripe.com/00wfZggVEcLs3DVfhi8bS05";

// „Was du in 2 Stunden baust"
const liefert = [
  "Deine KI-Wirkungs-Doku — belegt Vorher/Nachher deiner Arbeit und macht deinen Tagessatz und deine Verlängerung argumentierbar. (Flagship-Prozess der Session.)",
  "Deinen persönlichen KI-Baukasten — die Prompts und Bausteine dazu, dokumentiert und sofort wiederverwendbar.",
  "Fertige Vorlagen zum direkten Weiternutzen im nächsten Mandat.",
  "Aufzeichnung der Session — zum Nachbauen im eigenen Takt.",
  "Aufgebaut auf deiner eigenen Seite, nie im Kundensystem.",
];

// WP-09 — FAQPage (GEO/SEO). Sichtbare Q&A + JSON-LD müssen übereinstimmen (Google-Vorgabe).
const faqs = [
  {
    question: "Wie läuft der KI-Kickstart ab?",
    answer:
      "2 Stunden, live, in kleiner Gruppe (max. 15). Kein Frontal-Webinar — du baust mit, und am Ende der Session läuft dein KI-Prozess.",
  },
  {
    question: "Was baue ich konkret?",
    answer:
      "Deine KI-Wirkungs-Doku als Flagship-Prozess plus deinen persönlichen KI-Baukasten mit Prompts und Bausteinen — dokumentiert, sofort wiederverwendbar und auf deiner eigenen Seite aufgebaut.",
  },
  {
    question: "Bleiben meine vertraulichen Mandatsdaten sicher?",
    answer:
      "Ja. Alles wird auf deiner eigenen Seite aufgebaut, nie im System deines Auftraggebers. Sensible Mandatsdaten musst du für die Session nicht offenlegen.",
  },
  {
    question: "Was, wenn am Ende kein KI-Prozess läuft?",
    answer:
      "Dann bekommst du die 97 € zurück. Geld-zurück-Garantie: Läuft am Ende der Session kein KI-Prozess bei dir, erstatte ich den vollen Betrag.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};
---

<Base
  title="KI-Kickstart — dein erster KI-Prozess in 2 Stunden (97 €) | Value Lift AI"
  description="In 2 Stunden live baust du dir einen wiederverwendbaren KI-Prozess an deinem realen Mandats-Engpass. 97 € Festpreis, Geld zurück, wenn am Ende kein KI-Prozess läuft. Für solo Interim-Manager."
  path="/kickstart"
  hideNav={true}
>
  <!-- Mini-Logo-Header (hideNav entfernt den globalen Header) -->
  <header class="bg-brand-dark">
    <div class="mx-auto max-w-6xl px-4 py-4 sm:px-6">
      <a href="/" class="inline-flex items-center" aria-label="Zur Startseite">
        <img src="/logo.svg" alt="Value Lift AI" width="44" height="44" class="h-11 w-11" />
      </a>
    </div>
  </header>

  <!-- 1 · Hero -->
  <section class="bg-brand-dark text-brand-white">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 sm:py-24">
      <span
        class="mb-6 inline-block rounded-full border border-brand-blue bg-brand-blue/10 px-4 py-1 text-sm font-semibold text-brand-blueLight"
      >
        Für solo Interim-Manager · Einstieg
      </span>
      <h1 class="text-balance text-4xl font-extrabold leading-tight sm:text-5xl">
        Dein erster KI-Prozess, der im Mandat sofort trägt — in 2 Stunden.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300">
        Kein Kurs zum Wegklicken, kein Tool-Zoo. In einer kompakten Live-Session baust
        du dir einen wiederverwendbaren KI-Prozess an deinem realen Mandats-Engpass —
        und nimmst ihn fertig mit.
      </p>
      <p class="mt-8 text-xl font-extrabold text-brand-blueLight">
        97 € Festpreis · 2h · Live · Gruppe (max. 15)
      </p>
      <div class="mt-8">
        <a
          href={stripeUrl}
          target="_blank"
          rel="noopener"
          class="inline-block rounded-lg bg-brand-blue px-8 py-4 font-bold text-brand-black shadow-lg hover:bg-brand-blueLight"
        >
          Jetzt buchen — 97 €
        </a>
        <p class="mt-3 text-sm text-gray-400">
          Sofort buchbar. Geld zurück, wenn am Ende kein KI-Prozess läuft.
        </p>
      </div>
    </div>
  </section>

  <!-- 2 · Problem / Avatar-Resonanz -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="text-3xl font-extrabold">
        Im Mandat zählt nicht, was du könntest — sondern was diese Woche läuft.
      </h2>
      <p class="mt-6 text-lg text-brand-gray">
        KI selbst sauber aufzusetzen kostet Zeit, die du gerade nicht hast. Also bleibt
        es beim Herumprobieren zwischen zwei Terminen — und beim nächsten Mandat fängst
        du wieder bei null an.
      </p>
      <p class="mt-6 text-xl font-bold text-brand-dark">
        Der KI-Kickstart durchbricht das: ein fertiger Prozess, den du danach immer
        wieder nutzt.
      </p>
    </div>
  </section>

  <!-- 3 · Was du in 2 Stunden baust -->
  <section class="bg-brand-lightBg py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 class="text-center text-3xl font-extrabold">Was du in 2 Stunden baust.</h2>
      <ul class="mx-auto mt-10 max-w-2xl space-y-4">
        {
          liefert.map((item) => (
            <li class="flex items-start gap-3 rounded-xl border border-gray-200 bg-brand-white p-4">
              <span class="mt-0.5 font-bold text-brand-blue" aria-hidden="true">✓</span>
              <span class="text-base text-brand-dark">{item}</span>
            </li>
          ))
        }
      </ul>
      <p class="mx-auto mt-8 max-w-2xl text-center text-lg text-brand-gray">
        2 Stunden, live, in kleiner Gruppe (max. 15). Kein Frontal-Webinar — du baust
        mit, am Ende läuft dein Prozess.
      </p>
    </div>
  </section>

  <!-- 4 · Accountability-Differenzierer -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="text-3xl font-extrabold">Trainer, nicht Fitnessstudio.</h2>
      <p class="mt-6 text-lg text-brand-gray">
        Andere geben dir Tools und lassen dich allein — das Fitnessstudio. Ich bin der
        Trainer: In der Session bleibe ich dran, bis dein KI-Prozess läuft und du ihn
        selbst wieder aufrufen kannst.
      </p>
    </div>
  </section>

  <!-- 5 · Geld-zurück-Garantie -->
  <section class="bg-brand-lightBg py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <div class="rounded-2xl border border-gray-200 bg-brand-white p-8 text-center shadow-sm">
        <p class="text-lg font-semibold text-brand-dark">
          <span aria-hidden="true">🛡️</span> Geld-zurück-Garantie: Läuft am Ende der
          Session kein KI-Prozess bei dir, bekommst du die 97 € zurück.
        </p>
      </div>
    </div>
  </section>

  <!-- 6 · Wer das leitet -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto flex max-w-3xl flex-col items-center gap-8 px-4 sm:px-6 md:flex-row md:items-start">
      <img
        src="/marcus.jpg"
        alt="Marcus Eichler, KI-Architekt bei Value Lift AI"
        width="128"
        height="128"
        class="h-32 w-32 flex-shrink-0 rounded-full object-cover"
        style="border:3px solid #F5A623;"
      />
      <div>
        <h2 class="text-3xl font-extrabold">Wer das leitet.</h2>
        <p class="mt-4 text-lg text-brand-gray">
          Marcus Eichler — KI-Architekt und selbst Operator: Dipl.-Wirtschaftsingenieur,
          KI seit 2004, Lean Six Sigma Master Black Belt, CEO-Exit, &gt;1 Mrd. € Impact
          bei Telefónica. Er kennt den Druck im Mandat aus eigener Erfahrung.
        </p>
      </div>
    </div>
  </section>

  <!-- 6b · FAQ (WP-09) — sichtbare Q&A passend zum FAQPage-JSON-LD -->
  <section class="bg-brand-lightBg py-16 sm:py-20" id="faq">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <h2 class="text-center text-3xl font-extrabold">Häufige Fragen</h2>
      <div class="mt-10 space-y-4">
        {
          faqs.map((faq) => (
            <details class="rounded-xl border border-gray-200 bg-brand-white p-5 [&_summary]:list-none">
              <summary class="cursor-pointer font-bold text-brand-dark">{faq.question}</summary>
              <p class="mt-3 text-brand-gray">{faq.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 7 · Schluss-CTA -->
  <section class="bg-brand-dark py-16 text-center text-brand-white sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <h2 class="text-3xl font-extrabold">Bereit für deinen ersten KI-Prozess?</h2>
      <p class="mt-4 text-lg text-gray-300">
        97 € Festpreis · 2h · Live · Gruppe (max. 15). Am Ende läuft dein Prozess — oder
        du bekommst dein Geld zurück.
      </p>
      <a
        href={stripeUrl}
        target="_blank"
        rel="noopener"
        class="mt-8 inline-block rounded-lg bg-brand-blue px-8 py-4 font-bold text-brand-black hover:bg-brand-blueLight"
      >
        Jetzt buchen — 97 €
      </a>
      <p class="mt-4 text-sm text-gray-400">
        Unsicher, ob's passt?
        <a href="/buchen" class="underline hover:text-brand-blueLight">20-Min-Erstgespräch, kostenlos.</a>
      </p>
      <!-- Cross-Link → KI-Sprint (dezent) -->
      <p class="mt-6 text-sm text-gray-400">
        Willst du nicht einen Prozess, sondern dein ganzes Akquise-System aufbauen?
        <a href="/werkstatt" class="underline hover:text-brand-blueLight">→ KI-Sprint (8 Wochen)</a>
      </p>
    </div>
  </section>

  <!-- FAQPage JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>
