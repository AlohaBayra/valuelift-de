---
import Base from "../layouts/Base.astro";
import { GARANTIE_KERN } from "../lib/garantie";

// UM-01 — Landingpage „Mandats-Kickstart" (IM-Pivot, Modell B)
// Layout: Base.astro + hideNav (self-hosted Fonts + Consent/GTM intakt), eigener Mini-Header.
// Leitplanken: KEIN Preis · EIN Versprechen · EIN CTA = kostenloses Erstgespräch (/buchen)
//   · genau 1 Cross-Link → /werkstatt · Umsetzungs-Garantie (Prozess/Lieferung, nie Mandat/Erfolg).
// Garantie-/DSGVO-Wortlaut = FREIGEGEBEN (UM-10, Anhang E, Marcus 2026-06-22).

// Anhang C — „Was du sofort erhältst" (Outcome-formuliert)
const liefert = [
  "Eine konkrete KI-Anwendung an deinem realen Mandats-Engpass — fertig nutzbar, nicht als Prototyp.",
  "Automatisiertes Reporting-Set — Wochen-/Statusbericht in Minuten statt Stunden, bessere Optik.",
  "Analyse-Vorlagen — Mandatsdaten schnell auswerten, ohne bei null zu starten.",
  "Stakeholder-Map-Generator — in den ersten Tagen sofort sehen, wer wofür steht.",
  "100-Tage-Briefing-Aufbereitung — Unterlagenberge → strukturiertes Einarbeitungs-Briefing.",
  "KI-Wirkungs-Doku — Vorher/Nachher belegen → Argument für Verlängerung und Tagessatz.",
  "Aufbau auf der eigenen Infrastruktur — nichts Sensibles verlässt das Kundensystem.",
  "Übergabe so, dass du es ohne mich weiterführst — kein Abo, kein Vendor-Lock-in.",
];

// Anhang D — Mandatsphasen-Mehrwert-Karte (flexibler Einstieg, statisches Grid)
const phasen = [
  { phase: "0 · Vor Mandatsantritt", wo: "Mandat zugesagt, Start naht", wert: "Schnellstart-Set steht ab Tag 1." },
  { phase: "1 · Onboarding (erste Tage)", wo: "gerade eingestiegen", wert: "Schnelleinarbeitung, Stakeholder-Map, Briefing-Aufbereitung." },
  { phase: "2 · Erste 100 Tage", wo: "Wirkung zeigen unter Druck", wert: "Reporting-Automation + schnelle Analysen → früh sichtbare Ergebnisse." },
  { phase: "3 · Laufendes Mandat", wo: "mitten in der Steuerung", wert: "Laufende Reports + Prozess-Automatisierung → Entlastung." },
  { phase: "4 · Mandatsende / Übergabe", wo: "Abschluss & Übergabe", wert: "Wirkungs-Doku + Abschlussbericht → Tagessatz-Beleg fürs nächste Mandat." },
];

// WP-09 — FAQPage (GEO/SEO). Sichtbare Q&A + JSON-LD müssen übereinstimmen (Google-Vorgabe).
const faqs = [
  {
    question: "Wie lange dauert der Mandats-Kickstart?",
    answer:
      "In Tagen statt Monaten. Der Mandats-Kickstart hat einen festen Lieferrahmen und setzt KI dort an, wo sie in deinem Mandat heute am meisten trägt.",
  },
  {
    question: "Wie viel Zeit muss ich selbst investieren?",
    answer:
      "Dein Zeiteinsatz bleibt schlank: rechne mit rund 2–3 Stunden Mitwirkung, über die Liefertage verteilt.",
  },
  {
    question: "Bleiben meine vertraulichen Mandatsdaten sicher?",
    answer:
      "Die Werkzeuge werden auf deiner eigenen Infrastruktur aufgebaut, ohne Zugriff auf die Systeme deines Auftraggebers. Nichts Sensibles verlässt dein Mandat.",
  },
  {
    question: "Was, wenn die Werkzeuge nicht laufen?",
    answer:
      "Es gilt die Umsetzungs-Garantie: Wir arbeiten so lange mit dir weiter, bis dein erster KI-Prozess läuft. Bedingung ist deine Mitarbeit an den vereinbarten Schritten. Keine Zusage auf ein bestimmtes Mandat, einen Umsatz oder ein Ergebnis.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};
---

<Base
  title="Mandats-Kickstart — KI in deinem laufenden Mandat | Value Lift AI"
  description="KI-Werkzeuge auf deiner eigenen Seite, fertig im laufenden Mandat: Reporting, Analyse, Stakeholder-Map, Wirkungs-Doku. Für solo Interim-Manager. Auf Anfrage, kostenloses Erstgespräch."
  path="/kickstart"
  hideNav={true}
>
  <!-- Mini-Logo-Header (hideNav entfernt den globalen Header) -->
  <header class="bg-brand-dark">
    <div class="mx-auto max-w-6xl px-4 py-4 sm:px-6">
      <a href="/" class="inline-flex items-center" aria-label="Zur Startseite">
        <img src="/logo.svg" alt="Value Lift AI" width="44" height="44" class="h-11 w-11" />
      </a>
    </div>
  </header>

  <!-- 1 · Hero (Anhang A, Var A — Outcome) -->
  <section class="bg-brand-dark text-brand-white">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 sm:py-24">
      <span
        class="mb-6 inline-block rounded-full border border-brand-blue bg-brand-blue/10 px-4 py-1 text-sm font-semibold text-brand-blueLight"
      >
        Mandats-Kickstart · für solo Interim-Manager
      </span>
      <h1 class="text-balance text-4xl font-extrabold leading-tight sm:text-5xl">
        KI, die deinen Tagessatz in diesem Mandat sichtbar trägt.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300">
        Fester Rahmen, in Tagen statt Monaten. Angeleitet auf deiner eigenen Seite gebaut,
        nie in deinem Kundensystem. Du lieferst — sichtbar. Dein Zeiteinsatz bleibt schlank:
        rechne mit rund 2–3 Stunden Mitwirkung, über die Liefertage verteilt.
      </p>
      <div class="mt-10">
        <a
          href="/buchen"
          class="inline-block rounded-lg bg-brand-blue px-8 py-4 font-bold text-brand-black shadow-lg hover:bg-brand-blueLight"
        >
          Kostenloses Erstgespräch buchen
        </a>
        <p class="mt-3 text-sm text-gray-400">
          20 Minuten · kein Pitch · wir klären, was in deinem Mandat heute am meisten trägt.
        </p>
      </div>
    </div>
  </section>

  <!-- 2 · Schmerz / Avatar-Resonanz (Anhang A) -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="text-3xl font-extrabold">
        Im laufenden Mandat zählt nicht, was du könntest — sondern was diese Woche auf dem Tisch liegt.
      </h2>
      <p class="mt-6 text-lg text-brand-gray">
        KI selbst aufzusetzen kostet die Zeit, die du gerade nicht hast. Und jeder
        Tag ohne sichtbares Ergebnis ist ein Tag, an dem dein Honorar stiller
        hinterfragt wird.
      </p>
      <p class="mt-6 text-xl font-bold text-brand-dark">
        Der Mandats-Kickstart setzt KI dort an, wo sie heute am meisten trägt — in Tagen, nicht Monaten.
      </p>
    </div>
  </section>

  <!-- 3 · Was du sofort erhältst (Anhang C) -->
  <section class="bg-brand-lightBg py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 class="text-center text-3xl font-extrabold">Was du sofort erhältst.</h2>
      <p class="mt-4 text-center text-lg text-brand-gray">
        KI-Werkzeuge auf deiner eigenen Seite — fertig nutzbar im laufenden Mandat.
      </p>
      <ul class="mx-auto mt-10 max-w-2xl space-y-4">
        {
          liefert.map((item) => (
            <li class="flex items-start gap-3 rounded-xl border border-gray-200 bg-brand-white p-4">
              <span class="mt-0.5 font-bold text-brand-blue" aria-hidden="true">✓</span>
              <span class="text-base text-brand-dark">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 4 · Mandatsphasen-Mehrwert-Karte (Anhang D, statisches Grid) -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-extrabold">Egal wo du im Mandat stehst.</h2>
        <p class="mt-4 text-lg text-brand-gray">
          Wir steigen an dem Punkt ein, der heute am meisten trägt — flexibel nach Mandatsphase.
        </p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {
          phasen.map((p) => (
            <article class="flex flex-col rounded-2xl border border-gray-200 bg-brand-lightBg p-6">
              <p class="text-sm font-bold uppercase tracking-wide text-brand-blue">{p.phase}</p>
              <p class="mt-2 font-semibold text-brand-dark">{p.wo}</p>
              <p class="mt-2 flex-1 text-sm text-brand-gray">{p.wert}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 5 · DSGVO-Leitplanke (UM-10, Anhang E final)
       WP-08 [ENTWURF – 🔴 Jura vor Live gegenprüfen]: Umgang mit vertraulichen Mandatsdaten
       präzisiert, ohne die Haftung allein auf den IM abzuwälzen. -->
  <section class="bg-brand-dark py-16 text-brand-white sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="text-3xl font-extrabold">Gebaut ohne Zugriff auf das System deines Auftraggebers.</h2>
      <p class="mt-6 text-lg text-gray-300">
        Die Werkzeuge werden auf deiner eigenen Infrastruktur aufgebaut, ohne Zugriff
        auf die Systeme deines Auftraggebers. Vertrauliche Mandatsdaten bleiben, wo sie
        hingehören: Wir arbeiten nach dem Prinzip der Datensparsamkeit, richten die
        Verarbeitung so lokal wie möglich ein und setzen keine Mandatsdaten ungefragt in
        öffentliche KI-Dienste.
      </p>
      <p class="mt-4 text-lg text-gray-300">
        Die datenschutzrechtliche Verantwortung tragen wir gemeinsam: Ich sorge dafür,
        dass die Werkzeuge technisch DSGVO-konform aufgesetzt sind, und unterstütze dich
        bei der Bewertung deines konkreten Einsatzes — die abschließende Freigabe für dein
        Mandat triffst du.
      </p>
    </div>
  </section>

  <!-- 6 · Accountability-Differenzierer (Anhang A) -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="text-3xl font-extrabold">Trainer, nicht Fitnessstudio.</h2>
      <p class="mt-6 text-lg text-brand-gray">
        Andere geben dir Tools und lassen dich allein — das Fitnessstudio. Ich bin
        der Trainer: Ich bleibe dran, bis die Anwendung in deinem Mandat steht und
        trägt.
      </p>
    </div>
  </section>

  <!-- 7 · Umsetzungs-Garantie (Anhang E final, UM-10 freigegeben) -->
  <section class="bg-brand-lightBg py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <h2 class="text-center text-3xl font-extrabold">Die Umsetzungs-Garantie.</h2>
      <p class="mt-6 text-lg text-brand-gray">{GARANTIE_KERN}</p>
    </div>
  </section>

  <!-- 8 · Über Marcus (Operator-Herkunft als Vertrauensanker) -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto flex max-w-3xl flex-col items-center gap-8 px-4 sm:px-6 md:flex-row md:items-start">
      <img
        src="/marcus.jpg"
        alt="Marcus Eichler, KI-Architekt bei Value Lift AI"
        width="128"
        height="128"
        class="h-32 w-32 flex-shrink-0 rounded-full object-cover"
        style="border:3px solid #F5A623;"
      />
      <div>
        <h2 class="text-3xl font-extrabold">Wer das baut.</h2>
        <p class="mt-4 text-lg text-brand-gray">
          Marcus Eichler, KI-Architekt bei Value Lift AI — und selbst Operator: 29
          Jahre Führungserfahrung, CEO-Exit, über 1 Milliarde Euro nachweisbarer
          Impact bei Telefónica, Lean Six Sigma Master Black Belt.
        </p>
        <p class="mt-4 text-lg text-brand-gray">
          Ich kenne den Druck im Mandat aus eigener Erfahrung — und zeige dir, wie du dir die
          KI-Werkzeuge, die genau dort liefern, selbst baust. Auf Augenhöhe, mit jemandem, der den
          Stuhl selbst besetzt hat.
        </p>
      </div>
    </div>
  </section>

  <!-- 8b · FAQ (WP-09) — sichtbare Q&A passend zum FAQPage-JSON-LD -->
  <section class="bg-brand-lightBg py-16 sm:py-20" id="faq">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <h2 class="text-center text-3xl font-extrabold">Häufige Fragen</h2>
      <div class="mt-10 space-y-4">
        {
          faqs.map((faq) => (
            <details class="rounded-xl border border-gray-200 bg-brand-white p-5 [&_summary]:list-none">
              <summary class="cursor-pointer font-bold text-brand-dark">{faq.question}</summary>
              <p class="mt-3 text-brand-gray">{faq.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 9 · Final-CTA (genau 1 CTA → /buchen) -->
  <section class="bg-brand-dark py-16 text-center text-brand-white sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <h2 class="text-3xl font-extrabold">Lass uns auf dein Mandat schauen.</h2>
      <p class="mt-4 text-lg text-gray-300">
        20 Minuten, kostenlos, kein Pitch. Wir klären, welche KI-Anwendung in deinem
        Mandat heute den größten Hebel hat.
      </p>
      <a
        href="/buchen"
        class="mt-8 inline-block rounded-lg bg-brand-blue px-8 py-4 font-bold text-brand-black hover:bg-brand-blueLight"
      >
        Kostenloses Erstgespräch buchen
      </a>
      <!-- 10 · genau 1 Cross-Link → /werkstatt (dezent) -->
      <p class="mt-6 text-sm text-gray-400">
        Mandat läuft bald aus und du willst dir selbst einen Akquise-Magneten bauen?
        <a href="/werkstatt" class="underline hover:text-brand-blueLight">→ Zur Werkstatt</a>
      </p>
    </div>
  </section>

  <!-- FAQPage JSON-LD (nur Kickstart-Fragen, kein Preis) -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>
