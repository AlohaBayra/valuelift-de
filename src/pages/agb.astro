---
import Base from "../layouts/Base.astro";
---

<Base
  title="AGB — Value Lift AI"
  description="Allgemeine Geschäftsbedingungen von Value Lift AI / Marcus Eichler."
  path="/agb"
>
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h1 class="text-3xl font-extrabold sm:text-4xl">
        Allgemeine Geschäftsbedingungen
      </h1>

      <div class="mt-6 rounded-xl border border-brand-blue/40 bg-brand-lightBg p-4 text-sm text-brand-gray">
        <strong class="text-brand-dark">Platzhalter:</strong> Diese AGB vor dem
        Go-Live durch eine vollständige, rechtsgeprüfte Fassung ersetzen
        (Leistungsumfang, Zahlung, Widerruf, Garantien, Haftung).
      </div>

      <div class="mt-8 space-y-6 text-brand-dark">
        <div>
          <h2 class="text-xl font-bold">§ 1 Geltungsbereich</h2>
          <p class="mt-2 text-brand-gray">[Platzhalter.]</p>
        </div>
        <div>
          <h2 class="text-xl font-bold">§ 2 Leistungen</h2>
          <p class="mt-2 text-brand-gray">
            [Beschreibung von KI-Kickstart, KI-Sprint und KI-Komplettsystem.]
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold">§ 3 Preise &amp; Zahlung</h2>
          <p class="mt-2 text-brand-gray">[Platzhalter.]</p>
        </div>
        <div>
          <h2 class="text-xl font-bold">§ 4 Garantien</h2>
          <p class="mt-2 text-brand-gray">
            [Geld-zurück- bzw. Fertigstellungs-Garantien je Angebot.]
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold">§ 5 Widerrufsrecht</h2>
          <p class="mt-2 text-brand-gray">[Platzhalter.]</p>
        </div>
      </div>
    </div>
  </section>
</Base>
