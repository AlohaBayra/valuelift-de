---
import Leadership from "../../layouts/Leadership.astro";

const bookingUrl = "https://tidycal.com/marcuseichler/kennenlerngesprach-mit-marcus-eichler-1wr7yd6";

const painPoints = [
  {
    title: "Konflikte werden vermieden / eskalieren",
    text: "Konflikte kosten dich Energie – egal ob du sie schluckst oder frontal austrägst. Du gehst schwierigen Gesprächen aus dem Weg oder wirst härter als du eigentlich willst. Beides führt zu Reibung, Unsicherheit im Team und schlaflosen Nächten. Statt Klarheit entsteht Daueranspannung.",
    img: "/leadership/pain-icon-0.png",
  },
  {
    title: "Grenzen setzen fühlt sich falsch an",
    text: "Du willst kooperativ führen – und sagst trotzdem zu oft Ja. Mehr Verantwortung, mehr Erwartungen, mehr Druck. Doch wenn du keine klaren Grenzen setzt, verlierst du Fokus und Respekt. Innerlich wächst der Frust, äußerlich bleibst du professionell – bis es kippt.",
    img: "/leadership/pain-icon-1.png",
  },
  {
    title: "Zwischen den Fronten zerrieben werden",
    text: "Du stehst zwischen Management, Team und Kollegen. Jede Entscheidung hat politische Folgen. Statt souverän zu führen, fühlst du dich getrieben – und beginnst, dich selbst zu hinterfragen.",
    img: "/leadership/pain-icon-2.png",
  },
  {
    title: "Fachlich stark — aber nicht wirksam genug",
    text: "Du weißt, was richtig wäre. Aber du setzt dich nicht durch. In Meetings dominieren lautere Persönlichkeiten. Deine Argumente sind gut, aber deine Wirkung verpufft. Sichtbarkeit, Selbstvertrauen und strategische Positionierung fehlen – und damit der sichere nächste Karriereschritt.",
    img: "/leadership/pain-icon-3.png",
  },
];

// LT06: Outcomes als konkrete Szenen statt abstrakte Zustände
const outcomes = [
  {
    title: "Klarheit statt Dauerzweifel",
    text: "Du weißt in jeder Situation, was du willst – und kannst Entscheidungen treffen, ohne wochenlang zu zweifeln. Du handelst aus innerer Stabilität, nicht aus Erwartungsdruck.",
    img: "/leadership/outcome-1.png",
  },
  {
    title: "Schwierige Gespräche – ruhig bis zum Ende",
    text: "Du führst das schwierige Gespräch mit dem Chef, dem Kollegen, dem Team – klar und ruhig bis zum Ende, ohne lauter zu werden und ohne nachts wachzuliegen.",
    img: "/leadership/outcome-2.png",
  },
  {
    title: "Dein Name fällt, wenn es zählt",
    text: "Dein Vorgesetzter denkt bei der nächsten offenen Stelle zuerst an dich – nicht weil du lauter warst, sondern weil du klarer warst.",
    img: "/leadership/outcome-3.png",
  },
];

const steps = [
  {
    label: "IST-ANALYSE",
    title: "IST- & Ziel Analyse",
    text: "Ich analysiere deine Ausgangssituation und finde gemeinsam mit dir heraus, woran deine Überzeugungskraft und dein Karrierewunsch bisher scheiterten. Wir schaffen Klarheit darüber, worauf du bei deiner Zusammenarbeit Wert legst.",
    bullets: ["Analyse deiner Ausgangssituation & Problemfelder", "Durchführung deiner Wunschsituations-Analyse", "Festlegung der Beratungsschwerpunkte"],
    img: "/leadership/step-1.png",
  },
  {
    label: "DEIN SELBSTGLAUBE",
    title: "Erkenne deine Spielregeln",
    text: "Erkenne deine und die Spielregeln deiner Mitspieler – und sprich sie gezielt an.",
    bullets: [],
    img: "/leadership/step-2.png",
  },
  {
    label: "DEIN FAHRPLAN",
    title: "Individueller Fahrplan",
    text: "Ich entwickle deinen individuellen Fahrplan, damit deine Stärken gezielt eingesetzt werden.",
    bullets: [],
    img: "/leadership/step-3.png",
  },
  {
    label: "UMSETZEN & ÜBERZEUGEN",
    title: "Sicherheit in der Umsetzung",
    text: "Du erhältst die Sicherheit in der Umsetzung. Wir üben gemeinsam und reflektieren – bis alles sitzt.",
    bullets: [],
    img: "/leadership/step-4.png",
  },
];

// LT03: Altersangabe korrigiert auf 30–45 (ICP)
// LT05: "ich" statt "wir"
const forWhom = [
  {
    title: "Für Fach- und Führungskräfte zwischen 30 und 45",
    text: "Die größten Karriereprobleme entstehen oft genau dann, wenn du fachlich am stärksten bist. Die Ausbildung ist abgeschlossen. Die Ergebnisse stimmen. Trotzdem passiert der nächste Schritt an dir vorbei. Die Folge? Man wartet – und wartet.",
    img: "/leadership/forwhom-1.png",
  },
  {
    title: "Du willst den nächsten Karriereschritt",
    text: "Du weißt, dass mehr in dir steckt. Fachlich bist du stark, deine Ergebnisse stimmen – aber Wirkung, Sichtbarkeit oder strategische Positionierung fühlen sich noch nicht stabil an. Du weißt, dass du nicht zufällig befördert wirst, sondern gezielt wachsen möchtest.",
    img: "/leadership/forwhom-2.png",
  },
  {
    title: "Du willst belastende Gespräche souverän meistern",
    text: "Du willst kooperativ arbeiten, aber nicht ausgenutzt werden. Du sagst zu oft Ja, übernimmst zu viel Verantwortung oder vermeidest klare Ansagen. Gleichzeitig spürst du: So kann es nicht bleiben. Du möchtest respektvoll, ruhig und bestimmt auftreten – ohne schlechtes Gewissen.",
    img: "/leadership/forwhom-3.png",
  },
];

// LT11: Stärkste Testimonials (Klarnamen) zuerst, anonymes ans Ende
const testimonials = [
  {
    quote: "Marcus ist eine Führungskraft, die Menschen und ihre Stärken in den Mittelpunkt stellt. Er hat die einzigartige Gabe, die individuellen Talente jedes Teammitglieds nicht nur zu erkennen, sondern gezielt zu fördern. Er hat meinen Wunsch, mich in Richtung Führungskraft zu entwickeln, früh erkannt und mir zu gegebener Zeit die Chance gegeben.",
    name: "Daniela Baum",
    role: "Head of BI & Analytics // Dozentin",
    icon: "/leadership/quote-center.png",
  },
  {
    quote: "Im Coaching mit Marcus konnte ich mein eigenes Verhalten und meine Wirkung auf andere reflektieren. Ich habe gelernt, meine Muster zu hinterfragen und situativ zu adaptieren. Dadurch gelingt es mir heute, Abstand zu gewinnen, Situationen rationaler zu betrachten und mein Gegenüber für mich zu gewinnen. Ich empfehle Marcus uneingeschränkt.",
    name: "Blazej Gackowski",
    role: "Quality Assurance Engineer",
    icon: "/leadership/quote-left.png",
  },
  {
    quote: "In unserer gemeinsamen Zeit des Coachings bin ich nochmal enorm persönlich gewachsen. Ich habe gelernt, dass es okay ist, nicht immer direkt eine Lösung zu kennen. Ich habe gelernt, dass ich mich zurücknehmen darf und die Situation von außen betrachten darf. Es ist okay emotional zu sein – dies ist keine Schwäche, sondern ebenfalls eine Stärke.",
    name: "Svantje Knöbel",
    role: "Geschäftsführerin",
    icon: "/leadership/quote-center.png",
  },
  {
    quote: "Ich habe aus erster Hand erlebt, wie außergewöhnlich Marcus als Führungspersönlichkeit wirkt – er überzeugt durch seine Fähigkeit, Prozesse zu analysieren und zu verbessern, was zu systematischen Optimierungen führt, die Effizienz und Ergebnisse nachhaltig steigern.",
    name: "Batu Karabulut",
    role: "HO int. Key Account Management",
    icon: "/leadership/quote-right.png",
  },
  {
    quote: "Marcus verfügt über starke Führungsqualitäten, er kommuniziert Visionen klar und übersetzt innovative Ideen in umsetzbare Strategien, mit denen wir unser Team motivieren, inspirieren und die Unternehmensleistung steigern konnten.",
    name: "Dana Barette",
    role: "President Displays2Go",
    icon: "/leadership/quote-left.png",
  },
  {
    quote: "Die Zusammenarbeit mit Marcus war eine bereichernde Erfahrung. Er löst Probleme effizient und führt Projekte erfolgreich zum Abschluss. Ich empfehle Marcus wärmstens für seine außergewöhnliche Fähigkeit, Technologie mit praxisnahen Geschäftsstrategien zu verbinden.",
    name: "Maksym Shvaykovsky",
    role: "Engineering Leader",
    icon: "/leadership/quote-center.png",
  },
  {
    quote: "Ich bin zwar beruflich erfolgreich, war aber relativ planlos im Hinblick auf den weiteren Karriereweg. Marcus hat systematisch meine Stärken und Defizite mit mir aufbereitet. Ich bin mir nun viel besser bewusst, wo es künftig hingehen kann und was ich tun muss um das zu erreichen.",
    name: "Anonym",
    role: "Energie-Experte",
    icon: "/leadership/quote-right.png",
  },
];

// LT04: Trust-Logos mit Beschriftung
const trustLogos = [
  { src: "/leadership/trust-1.png", alt: "Referenz 1" },
  { src: "/leadership/trust-2.png", alt: "Referenz 2" },
  { src: "/leadership/trust-3.png", alt: "Referenz 3" },
  { src: "/leadership/trust-4.png", alt: "Referenz 4" },
  { src: "/leadership/trust-5.png", alt: "Referenz 5" },
];

// LT08: Mini-FAQ Einwandbehandlung
const faq = [
  {
    q: "Ist das wieder nur Mindset-Coaching?",
    a: "Nein. Ich arbeite an konkretem Verhalten in deinen realen Situationen – nicht an abstrakten Glaubenssätzen. Du gehst mit einem klaren Fahrplan raus, kein Notizbuch voller Inspirationszitate.",
  },
  {
    q: "Ich habe kaum Zeit für Coaching.",
    a: "Genau deshalb arbeite ich gezielt, statt breit. Das Erstgespräch dauert 30 Minuten. Den Rest passen wir an deine Situation an.",
  },
  {
    q: "Was passiert nach dem Gespräch – werde ich zum Kauf gedrängt?",
    a: "Nein. Du gehst mit einer klaren Einschätzung raus, ob mein Ansatz zu dir passt oder nicht. Kein Pitch, kein Druck.",
  },
  {
    q: "Für wen ist das nicht das Richtige?",
    a: "Wenn du aktuell nur einen neuen Job suchst oder eine schnelle Abkürzung ohne eigene Arbeit willst – dann passt das nicht. Mein Ansatz braucht Bereitschaft zur Reflexion.",
  },
];
---

<Leadership
  title="In Führung gehen – Coaching für souveräne Führung & Karriere | Marcus Eichler"
  description="Karriere ist kein Glück. Marcus Eichler coacht Fach- und Führungskräfte dabei, Wirkung und Sichtbarkeit gezielt aufzubauen – souverän, klar und ohne Selbstverleugnung."
  path="/leadership"
>

  <!-- Hero — Full-Bleed wie Original-Seite: Marcus-Foto rechts, Text links -->
  <section style="position: relative; background-color: #0A1628; color: #FFFFFF; min-height: 600px; overflow: hidden;">

    <!-- Marcus Foto: rechte Hälfte, volle Höhe -->
    <div style="position: absolute; top: 0; right: 0; width: 50%; height: 100%; min-height: 600px;">
      <img src="/leadership/marcus-about.jpeg" alt="Marcus Eichler"
        style="width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block;" />
      <!-- Gradient links: Foto → dunkler Hintergrund -->
      <div style="position: absolute; top: 0; left: 0; width: 60%; height: 100%;
        background: linear-gradient(to right, #0A1628 0%, rgba(10,22,40,0.7) 60%, transparent 100%);"></div>
    </div>

    <!-- Text-Inhalt: linke Hälfte -->
    <div style="position: relative; z-index: 1; max-width: 64rem; margin: 0 auto; padding: 5rem 1rem 4rem;">
      <div style="max-width: 36rem;">
        <p style="font-size: 0.8125rem; font-weight: 700; color: #93C5FD; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">
          Coaching für Fach- und Führungskräfte
        </p>

        <!-- LT01 -->
        <h1 style="font-size: 2.75rem; font-weight: 800; line-height: 1.1; margin-bottom: 1.5rem;">
          Karriere ist kein Glück. Sie ist ein Prozess – den die meisten kompetenten Leute nie steuern.
        </h1>

        <!-- LT02 -->
        <p style="font-size: 1.0625rem; color: rgba(255,255,255,0.88); line-height: 1.75; margin-bottom: 2rem;">
          Du lieferst ab. Du übernimmst Verantwortung. Trotzdem ziehen andere an dir vorbei. Der Grund ist nicht fehlende Leistung – sondern dass dir niemand gezeigt hat, wie man Wirkung und Sichtbarkeit gezielt aufbaut. Genau das machen wir steuerbar.
        </p>

        <!-- LT09 + LT07 -->
        <a href={bookingUrl} target="_blank" rel="noopener"
          style="display: inline-block; background-color: #015FA3; color: #FFFFFF; font-weight: 700; padding: 1rem 2rem; border-radius: 0.5rem; text-decoration: none; font-size: 1rem; margin-bottom: 0.75rem;">
          Kostenloses Erstgespräch buchen
        </a>
        <p style="font-size: 0.8125rem; color: rgba(255,255,255,0.6); margin-bottom: 2.5rem;">
          30 Min per Video. Klare Einschätzung deiner Situation – kein Pitch, kein Druck.
        </p>

        <p style="font-size: 0.875rem; color: rgba(255,255,255,0.65); margin-bottom: 0.75rem;">
          Mit der Erfahrung aus über 29 Jahren Führung, Transformation und Verantwortung
        </p>
        <ul style="list-style: none; padding: 0; margin: 0 0 2.5rem; display: flex; flex-direction: column; gap: 0.4rem;">
          {["Vom Elektriker bis zum CEO", "Führung von Organisationen bis 250+ Mitarbeiter", "Umsetzung komplexer Transformations- & Veränderungsprojekte", "Coaching von Fach- und Führungskräften an entscheidenden Karrierepunkten"].map(item => (
            <li style="display: flex; gap: 0.6rem; font-size: 0.9375rem; color: rgba(255,255,255,0.85);">
              <span style="color: #93C5FD; flex-shrink: 0;">✓</span> {item}
            </li>
          ))}
        </ul>

        <!-- LT04 -->
        <p style="font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em;">
          Stationen aus 29 Jahren Führung – vom Elektriker zum CEO
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;">
          {trustLogos.map(logo => (
            <img src={logo.src} alt={logo.alt} style="height: 36px; width: auto; object-fit: contain; filter: brightness(0) invert(1); opacity: 0.6;" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Brücken-Section — LT12, LT05 -->
  <section style="background-color: #EFF6FF; padding: 4rem 1rem; text-align: center;">
    <div style="max-width: 42rem; margin: 0 auto;">
      <h2 style="font-size: 1.875rem; font-weight: 800; color: #0A1628; margin-bottom: 0.75rem;">
        Intern weiterkommen – mit Strategie statt Glück
      </h2>
      <!-- LT12: Schärfere Formulierung -->
      <p style="font-size: 1.0625rem; color: #374151; line-height: 1.7; margin-bottom: 0.75rem;">
        Du gibst im Job alles – und merkst trotzdem, dass dich das nicht weiterbringt, sondern nur auslaugt.
      </p>
      <!-- LT05: "ich" statt "wir" -->
      <p style="font-size: 1.0625rem; font-weight: 600; color: #015FA3;">
        Mit meinem 4-stufigen Ansatz machen wir deine Karriere steuerbar.
      </p>
    </div>
  </section>

  <!-- Pain Points — LT05 -->
  <section style="background-color: #FFFFFF; padding: 4rem 1rem;">
    <div style="max-width: 56rem; margin: 0 auto;">
      <p style="font-size: 0.8125rem; font-weight: 700; color: #015FA3; text-transform: uppercase; letter-spacing: 0.1em; text-align: center; margin-bottom: 0.5rem;">Das steht dir im Weg</p>
      <h2 style="font-size: 1.875rem; font-weight: 800; color: #0A1628; text-align: center; margin-bottom: 0.75rem;">
        An diesen Herausforderungen scheitern kompetente Leute
      </h2>
      <p style="font-size: 1rem; color: #6B7280; text-align: center; max-width: 42rem; margin: 0 auto 3rem; line-height: 1.7;">
        Für viele Fach- und Führungskräfte fühlt sich der Arbeitsalltag wie ein ständiger Balanceakt an. Man gibt alles, übernimmt Verantwortung – aber wenn es um Konflikte, klare Worte oder die eigene Karriere geht, hält man sich zurück. Man funktioniert, aber führt nicht wirklich. Und das Gefühl, auf der Stelle zu treten, wird mit jedem Monat stärker.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem;">
        {painPoints.map(p => (
          <div style="border-radius: 1rem; border: 1px solid #DBEAFE; padding: 1.75rem; background-color: #F8FAFF;">
            <img src={p.img} alt={p.title} style="height: 56px; width: auto; margin-bottom: 1rem; object-fit: contain;" />
            <h3 style="font-weight: 700; color: #0A1628; font-size: 1rem; margin-bottom: 0.75rem;">{p.title}</h3>
            <p style="font-size: 0.9375rem; color: #4B5563; line-height: 1.65;">{p.text}</p>
          </div>
        ))}
      </div>
      <div style="text-align: center; margin-top: 3rem;">
        <p style="font-size: 1.0625rem; font-weight: 600; color: #0A1628; margin-bottom: 1.5rem;">
          Du erkennst dich wieder – weißt aber nicht, wie du da rauskommst?
        </p>
        <!-- LT09 + LT07 -->
        <a href={bookingUrl} target="_blank" rel="noopener"
          style="display: inline-block; background-color: #015FA3; color: #FFFFFF; font-weight: 700; padding: 1rem 2rem; border-radius: 0.5rem; text-decoration: none; font-size: 1rem; margin-bottom: 0.75rem;">
          Kostenloses Erstgespräch buchen
        </a>
        <p style="font-size: 0.8125rem; color: #9CA3AF;">30 Min per Video. Klare Einschätzung – kein Pitch, kein Druck.</p>
      </div>
    </div>
  </section>

  <!-- LT10: Philosophie-Teaser direkt nach Pain Points -->
  <section style="background-color: #0A1628; padding: 2.5rem 1rem; text-align: center;">
    <div style="max-width: 42rem; margin: 0 auto;">
      <p style="font-size: 1.125rem; color: rgba(255,255,255,0.9); line-height: 1.75; font-style: italic;">
        „Wirksamkeit entsteht nicht durch lauteres Auftreten oder bessere Techniken. Sie entsteht, wenn innere Klarheit, Persönlichkeit und äußeres Handeln zusammenpassen. Das ist erlernbar."
      </p>
      <p style="font-size: 0.9375rem; font-weight: 700; color: #93C5FD; margin-top: 1rem;">— Marcus Eichler</p>
    </div>
  </section>

  <!-- Outcomes — LT06, LT05 -->
  <section style="background-color: #EFF6FF; padding: 4rem 1rem;">
    <div style="max-width: 56rem; margin: 0 auto; text-align: center;">
      <h2 style="font-size: 1.875rem; font-weight: 800; color: #0A1628; margin-bottom: 3rem;">
        Was sich in deinem Alltag konkret verändert
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
        {outcomes.map(o => (
          <div style="border-radius: 1rem; background-color: #FFFFFF; border: 1px solid #DBEAFE; padding: 1.75rem; text-align: left;">
            <img src={o.img} alt={o.title} style="height: 72px; width: auto; margin-bottom: 1rem; object-fit: contain;" />
            <h3 style="font-weight: 700; color: #0A1628; font-size: 1rem; margin-bottom: 0.6rem;">{o.title}</h3>
            <p style="font-size: 0.9375rem; color: #4B5563; line-height: 1.65;">{o.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Termin CTA — LT09, LT07, LT05 -->
  <section style="background: linear-gradient(135deg, #015FA3 0%, #0A1628 100%); padding: 4rem 1rem;">
    <div style="max-width: 64rem; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 3rem; align-items: center; justify-content: center;">
      <div style="max-width: 38rem; text-align: center;">
        <p style="font-size: 0.8125rem; font-weight: 700; color: #93C5FD; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">Termin vereinbaren</p>
        <h2 style="font-size: 1.75rem; font-weight: 800; color: #FFFFFF; margin-bottom: 1.5rem;">
          Hör auf, auf die Beförderung zu warten, die nicht kommt. Fang an, Karriere zu steuern.
        </h2>
        <a href={bookingUrl} target="_blank" rel="noopener"
          style="display: inline-block; background-color: #FFFFFF; color: #015FA3; font-weight: 700; padding: 1rem 2rem; border-radius: 0.5rem; text-decoration: none; font-size: 1rem; margin-bottom: 0.75rem;">
          Kostenloses Erstgespräch buchen
        </a>
        <p style="font-size: 0.8125rem; color: rgba(255,255,255,0.6);">30 Min per Video. Klare Einschätzung – kein Pitch, kein Druck.</p>
      </div>
      <div style="flex-shrink: 0;">
        <img src="/leadership/termin-visual.png" alt="Coaching Termin" style="max-width: 260px; width: 100%; height: auto; border-radius: 1rem; opacity: 0.9;" />
      </div>
    </div>
  </section>

  <!-- Für wen — LT03, LT05 -->
  <section style="background-color: #FFFFFF; padding: 4rem 1rem;">
    <div style="max-width: 56rem; margin: 0 auto;">
      <h2 style="font-size: 1.875rem; font-weight: 800; color: #0A1628; text-align: center; margin-bottom: 0.75rem;">
        Das ist für dich, wenn …
      </h2>
      <p style="font-size: 0.9375rem; color: #6B7280; text-align: center; margin-bottom: 3rem;">
        Und <strong>nicht</strong> für dich, wenn du nur einen neuen Job suchst oder eine schnelle Abkürzung ohne eigene Arbeit willst.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem;">
        {forWhom.map(f => (
          <div style="border-radius: 1rem; border: 2px solid #015FA3; background-color: #EFF6FF; padding: 1.75rem;">
            <img src={f.img} alt={f.title} style="height: 56px; width: auto; margin-bottom: 1rem; object-fit: contain;" />
            <h3 style="font-weight: 700; color: #0A1628; font-size: 1rem; margin-bottom: 0.75rem;">{f.title}</h3>
            <p style="font-size: 0.9375rem; color: #4B5563; line-height: 1.65;">{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials — LT11, LT05 -->
  <section style="background-color: #F8FAFF; padding: 4rem 1rem;">
    <div style="max-width: 64rem; margin: 0 auto;">
      <p style="font-size: 0.8125rem; font-weight: 700; color: #015FA3; text-transform: uppercase; letter-spacing: 0.1em; text-align: center; margin-bottom: 0.5rem;">Stimmen aus der Praxis</p>
      <h2 style="font-size: 1.875rem; font-weight: 800; color: #0A1628; text-align: center; margin-bottom: 3rem;">
        Das sagen Fach- und Führungskräfte, die mit mir gearbeitet haben
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
        {testimonials.map(t => (
          <div style="border-radius: 1rem; background-color: #FFFFFF; border: 1px solid #DBEAFE; padding: 1.75rem; display: flex; flex-direction: column; gap: 1rem;">
            <img src={t.icon} alt="Zitat" style="height: 36px; width: auto; object-fit: contain; opacity: 0.5;" />
            <p style="font-size: 0.9375rem; color: #374151; line-height: 1.7; font-style: italic; flex: 1;">„{t.quote}"</p>
            <div>
              <p style="font-weight: 700; color: #0A1628; margin: 0; font-size: 0.9375rem;">{t.name}</p>
              <p style="font-size: 0.8125rem; color: #6B7280; margin: 0;">{t.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4 Schritte Methode — LT05 -->
  <section style="background-color: #FFFFFF; padding: 4rem 1rem;">
    <div style="max-width: 56rem; margin: 0 auto; text-align: center;">
      <p style="font-size: 0.8125rem; font-weight: 700; color: #015FA3; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem;">Meine Strategie und Methode</p>
      <h2 style="font-size: 1.875rem; font-weight: 800; color: #0A1628; margin-bottom: 1rem;">
        In vier Schritten zu souveräner Wirkung
      </h2>
      <!-- LT09 + LT07 -->
      <a href={bookingUrl} target="_blank" rel="noopener"
        style="display: inline-block; background-color: #015FA3; color: #FFFFFF; font-weight: 700; padding: 0.875rem 1.75rem; border-radius: 0.5rem; text-decoration: none; font-size: 0.9375rem; margin-bottom: 0.75rem;">
        Kostenloses Erstgespräch buchen
      </a>
      <p style="font-size: 0.8125rem; color: #9CA3AF; margin-bottom: 3rem;">30 Min per Video. Klare Einschätzung – kein Pitch, kein Druck.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; text-align: left;">
        {steps.map(s => (
          <div style="border-radius: 1rem; border: 1px solid #DBEAFE; background-color: #F8FAFF; padding: 1.5rem;">
            <img src={s.img} alt={s.label} style="height: 64px; width: auto; margin-bottom: 0.75rem; object-fit: contain;" />
            <p style="font-size: 0.6875rem; font-weight: 700; color: #4A90E2; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.25rem;">{s.label}</p>
            <h3 style="font-weight: 700; color: #0A1628; font-size: 0.9375rem; margin-bottom: 0.5rem;">{s.title}</h3>
            <p style="font-size: 0.875rem; color: #4B5563; line-height: 1.6;">{s.text}</p>
            {s.bullets.length > 0 && (
              <ul style="margin-top: 0.75rem; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.3rem;">
                {s.bullets.map(b => (
                  <li style="font-size: 0.875rem; color: #4B5563; display: flex; gap: 0.4rem;"><span style="color: #015FA3;">✓</span> {b}</li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Philosophie + Stats — LT05 -->
  <section style="background: linear-gradient(160deg, #0A1628 0%, #015FA3 100%); color: #FFFFFF; padding: 4rem 1rem;">
    <div style="max-width: 56rem; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 3rem; align-items: center;">
      <div style="flex: 1; min-width: 260px;">
        <h2 style="font-size: 1.5rem; font-weight: 800; margin-bottom: 1rem;">
          Meine Arbeit beginnt nicht bei Tools, sondern bei deiner inneren Haltung
        </h2>
        <p style="font-size: 1rem; color: rgba(255,255,255,0.85); line-height: 1.7; margin-bottom: 1rem;">
          Viele Programme versprechen Sichtbarkeit. Andere zeigen dir, wie du dich „richtig" verhalten sollst. Ich halte beides für zu kurz gedacht.
        </p>
        <p style="font-size: 1rem; color: rgba(255,255,255,0.85); line-height: 1.7; font-style: italic; margin-bottom: 2rem;">
          Ich war 29 Jahre selbst in der Situation, andere zu führen, zu entwickeln und schwierige Entscheidungen zu treffen – auch die falschen. Ich coache nicht aus Büchern. Ich coache aus Erfahrung.
        </p>
        <p style="font-size: 0.9375rem; font-weight: 700; color: rgba(255,255,255,0.9); margin-bottom: 2rem;">
          29 Jahre Fach-, Führungs- &amp; Managementerfahrung im Konzern &amp; als Unternehmer
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 1.5rem;">
          <div style="text-align: center; background-color: rgba(255,255,255,0.1); border-radius: 1rem; padding: 1.25rem 1.5rem; min-width: 110px;">
            <p style="font-size: 2rem; font-weight: 800; color: #FFFFFF; margin: 0;">100%</p>
            <p style="font-size: 0.8125rem; color: rgba(255,255,255,0.75); margin: 0.25rem 0 0;">Führungsleidenschaft</p>
          </div>
          <div style="text-align: center; background-color: rgba(255,255,255,0.1); border-radius: 1rem; padding: 1.25rem 1.5rem; min-width: 110px;">
            <p style="font-size: 2rem; font-weight: 800; color: #FFFFFF; margin: 0;">+330</p>
            <p style="font-size: 0.8125rem; color: rgba(255,255,255,0.75); margin: 0.25rem 0 0;">Mitarbeiter entwickelt</p>
          </div>
          <div style="text-align: center; background-color: rgba(255,255,255,0.1); border-radius: 1rem; padding: 1.25rem 1.5rem; min-width: 110px;">
            <p style="font-size: 2rem; font-weight: 800; color: #FFFFFF; margin: 0;">+29</p>
            <p style="font-size: 0.8125rem; color: rgba(255,255,255,0.75); margin: 0.25rem 0 0;">Jahre Führung &amp; Management</p>
          </div>
        </div>
      </div>
      <div style="flex-shrink: 0;">
        <img src="/leadership/marcus-about.jpeg" alt="Marcus Eichler – Coaching"
          style="width: 260px; height: 320px; border-radius: 1rem; object-fit: cover; border: 3px solid rgba(255,255,255,0.2); box-shadow: 0 20px 50px rgba(0,0,0,0.4);" />
      </div>
    </div>
  </section>

  <!-- Trust Logos — LT04 -->
  <section style="background-color: #F8FAFF; padding: 2.5rem 1rem;">
    <p style="text-align: center; font-size: 0.75rem; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1.25rem;">
      Stationen aus 29 Jahren Führung – vom Elektriker zum CEO
    </p>
    <div style="max-width: 56rem; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center; justify-content: center;">
      {trustLogos.map(logo => (
        <img src={logo.src} alt={logo.alt} style="height: 40px; width: auto; object-fit: contain; opacity: 0.5; filter: grayscale(1);" />
      ))}
    </div>
  </section>

  <!-- LT08: Mini-FAQ Einwandbehandlung -->
  <section style="background-color: #FFFFFF; padding: 4rem 1rem;">
    <div style="max-width: 42rem; margin: 0 auto;">
      <h2 style="font-size: 1.5rem; font-weight: 800; color: #0A1628; text-align: center; margin-bottom: 2.5rem;">
        Häufige Fragen vor dem ersten Gespräch
      </h2>
      <div style="display: flex; flex-direction: column; gap: 1.25rem;">
        {faq.map(item => (
          <div style="border-radius: 0.75rem; border: 1px solid #DBEAFE; padding: 1.25rem 1.5rem; background-color: #F8FAFF;">
            <p style="font-weight: 700; color: #0A1628; font-size: 0.9375rem; margin: 0 0 0.5rem;">{item.q}</p>
            <p style="font-size: 0.9375rem; color: #4B5563; line-height: 1.65; margin: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Abschluss-CTA — LT09, LT07, LT05 -->
  <section style="background-color: #EFF6FF; padding: 4rem 1rem; text-align: center;">
    <div style="max-width: 42rem; margin: 0 auto;">
      <h2 style="font-size: 1.75rem; font-weight: 800; color: #0A1628; margin-bottom: 0.75rem;">
        Bereit für den ersten Schritt?
      </h2>
      <p style="font-size: 1rem; color: #4B5563; line-height: 1.7; margin-bottom: 2rem;">
        30 Minuten, per Video. Ich schaue mir deine konkrete Situation an und du gehst mit einer klaren Einschätzung raus – auch wenn wir nicht zusammenarbeiten.
      </p>
      <a href={bookingUrl} target="_blank" rel="noopener"
        style="display: inline-block; background-color: #015FA3; color: #FFFFFF; font-weight: 700; padding: 1rem 2.5rem; border-radius: 0.5rem; text-decoration: none; font-size: 1.0625rem; margin-bottom: 0.75rem;">
        Kostenloses Erstgespräch buchen
      </a>
      <p style="font-size: 0.8125rem; color: #9CA3AF;">Kein Pitch, kein Druck. Nur ehrliches Feedback zu deiner Situation.</p>
    </div>
  </section>

</Leadership>
