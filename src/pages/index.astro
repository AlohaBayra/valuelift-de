---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import OfferCards from "../components/OfferCards.astro";
import KiBeweis from "../components/KiBeweis.astro";
import { GARANTIE_KERN } from "../lib/garantie";

// IM-Pivot (Modell B): Startseite für solo Operations-/COO-Interim-Manager.
// Leitplanken: kein oeffentlicher Preis, kein Stripe, kein Coaching-Jargon; ein Hero-Versprechen; alle CTAs → /buchen.
// Segmentierung nach Mandatsphase, nie nach Preis. Garantie = Umsetzungs-Garantie (🔴 Wortlaut UM-10).

// WP-04 — Kompakter Mandatsphasen-Anker-Router (ersetzt die frühere doppelte Sektion).
// Zwei Haupt-Wege (Werkstatt/Kickstart) + Premium-auf-Anfrage als Ausnahme.
const weiche = [
  { status: "Zwischen Mandaten", cta: "Zur Werkstatt →", href: "/werkstatt" },
  { status: "Im oder vor dem Mandat", cta: "Zum Mandats-Kickstart →", href: "/kickstart" },
  { status: "Stabil, aber keine Hand frei", cta: "Premium auf Anfrage →", href: "/buchen" },
];

// WP-09 — FAQPage (GEO/SEO). Sichtbare Q&A + JSON-LD müssen übereinstimmen (Google-Vorgabe).
const faqs = [
  {
    question: "Für wen ist Value Lift AI?",
    answer:
      "Für solo Interim-Manager im Operations-/COO-Umfeld im DACH-Raum, die KI im Mandat sichtbar nutzen und ihre Pipeline warmhalten wollen — ohne dafür Programmierer zu werden.",
  },
  {
    question: "Baust du das System für mich oder baue ich es selbst?",
    answer:
      "Du baust es selbst — von mir angeleitet. So verstehst du jeden Schritt und bist danach unabhängig. Nur in Ausnahmen baue ich es dir auf Anfrage als Premium; die Unabhängigkeit aus dem Selberbauen ist der eigentliche Wert.",
  },
  {
    question: "Was kostet das?",
    answer:
      "Es gibt bewusst keinen öffentlichen Preis. Der richtige Weg hängt von deiner Mandatsphase ab, nicht vom Budget — den Rahmen klären wir im kostenlosen Erstgespräch.",
  },
  {
    question: "Welche Garantie gibt es?",
    answer:
      "Eine Umsetzungs-Garantie: Wir arbeiten so lange mit dir weiter, bis dein erster KI-Prozess läuft. Bedingung ist deine Mitarbeit an den vereinbarten Schritten. Keine Zusage auf ein bestimmtes Mandat, einen Umsatz oder ein Ergebnis.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};
---

<Base
  title="KI-Systeme für solo Interim-Manager (Operations & COO) | Value Lift AI"
  description="Das KI-System für solo Operations-/COO-Interim-Manager im DACH-Raum: im Mandat sichtbar liefern und die Pipeline warmhalten, während du im Einsatz bist. Kostenloses Erstgespräch."
  path="/"
>

  <!-- 1. Hero (UM-03) -->
  <Hero />

  <!-- 2. Hürden: woran Interim-Manager mit KI scheitern (ersetzt Akquise-Paradox) -->
  <section style="background-color: #FFFFFF; padding: 4rem 1rem;">
    <div style="max-width: 72rem; margin: 0 auto;">
      <p style="font-size: 0.8125rem; font-weight: 700; color: #F5A623; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 0.75rem;">
        Das hält dich auf
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 2rem; align-items: flex-start; margin-bottom: 2.75rem;">
        <h2 style="flex: 1; min-width: 300px; font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 800; color: #0B1528; line-height: 1.15; margin: 0;">
          Woran <span style="color: #F5A623;">„KI nebenbei"</span> im Mandat scheitert
        </h2>
        <p style="flex: 1; min-width: 280px; font-size: 1rem; color: #6B7280; line-height: 1.7; margin: 0;">
          Du probierst ChatGPT zwischen zwei Terminen. Mal klappt's, meist nicht — und für ein sauberes System fehlt im Mandat die Zeit. So bleibt KI eine Nebensache statt ein Hebel, der deinen Tagessatz rechtfertigt.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
        <article style="background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 1rem; padding: 1.75rem;">
          <div style="width: 48px; height: 48px; border-radius: 0.6rem; background: #F5A623; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; margin-bottom: 1.25rem;">⚠️</div>
          <h3 style="font-size: 1.125rem; font-weight: 800; color: #0B1528; line-height: 1.25; margin: 0 0 0.6rem;">Eine falsche Zahl — und dein Wort zählt nichts mehr</h3>
          <p style="font-size: 0.9375rem; color: #6B7280; line-height: 1.6; margin: 0;">KI erfindet plausible Details. Geht eine halluzinierte Zahl ungeprüft an den Auftraggeber, steht nicht die KI im Regen — sondern du. Genau das, wofür sie dich teuer bezahlen, ist dann beschädigt.</p>
        </article>
        <article style="background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 1rem; padding: 1.75rem;">
          <div style="width: 48px; height: 48px; border-radius: 0.6rem; background: #F5A623; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; margin-bottom: 1.25rem;">🔒</div>
          <h3 style="font-size: 1.125rem; font-weight: 800; color: #0B1528; line-height: 1.25; margin: 0 0 0.6rem;">Vertrauliche Daten im falschen Tool</h3>
          <p style="font-size: 0.9375rem; color: #6B7280; line-height: 1.6; margin: 0;">Mandatsdaten schnell in ein öffentliches KI-Tool gekippt — und die Vertraulichkeit ist weg. Im Mandat kein Schönheitsfehler, sondern ein Haftungsrisiko, das dein nächstes Mandat kosten kann.</p>
        </article>
        <article style="background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 1rem; padding: 1.75rem;">
          <div style="width: 48px; height: 48px; border-radius: 0.6rem; background: #F5A623; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; margin-bottom: 1.25rem;">🔁</div>
          <h3 style="font-size: 1.125rem; font-weight: 800; color: #0B1528; line-height: 1.25; margin: 0 0 0.6rem;">Jedes Mandat wieder bei null</h3>
          <p style="font-size: 0.9375rem; color: #6B7280; line-height: 1.6; margin: 0;">Ohne feste Methode beginnt jede Aufgabe von vorn — nichts baut aufeinander auf. Ist das Mandat vorbei, ist auch dein KI-Wissen weg. Du sammelst Prompts, baust aber kein Vermögen auf.</p>
        </article>
        <article style="background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 1rem; padding: 1.75rem;">
          <div style="width: 48px; height: 48px; border-radius: 0.6rem; background: #F5A623; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; margin-bottom: 1.25rem;">⏳</div>
          <h3 style="font-size: 1.125rem; font-weight: 800; color: #0B1528; line-height: 1.25; margin: 0 0 0.6rem;">Neben dem Mandat baust du es nie auf</h3>
          <p style="font-size: 0.9375rem; color: #6B7280; line-height: 1.6; margin: 0;">Zwischen 12-Stunden-Tagen bleibt keine Stunde, dir KI sauber selbst aufzusetzen. Also dokterst du weiter — allein, nebenbei, kommst du da nie raus.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- 2b. Einzelaktion → System (jopenau-Thema) -->
  <section style="background-color: #F9F7F7; padding: 4rem 1rem;">
    <div style="max-width: 48rem; margin: 0 auto;">
      <h2 style="font-size: clamp(1.625rem, 3vw, 2.125rem); font-weight: 800; color: #0B1528; line-height: 1.2; margin: 0 0 1.75rem; text-align: center;">
        Du nutzt KI im Mandat schon. Aber als Einzelaktion — nicht als System.
      </h2>
      <ul style="list-style: none; padding: 0; margin: 0 0 1.75rem; display: flex; flex-direction: column; gap: 1rem;">
        <li style="font-size: 1.0625rem; color: #374151; line-height: 1.7; padding-left: 1.1rem; border-left: 3px solid #F5A623;">
          Jedes Mal erklärst du ChatGPT von vorn, was du brauchst. Ergebnis okay — beim nächsten Mandat fängst du wieder bei null an.
        </li>
        <li style="font-size: 1.0625rem; color: #374151; line-height: 1.7; padding-left: 1.1rem; border-left: 3px solid #F5A623;">
          Kontext, Tonalität, dein Vorgehen: nach 200 Nachrichten „vergessen". Deine Eingaben sind weg.
        </li>
        <li style="font-size: 1.0625rem; color: #374151; line-height: 1.7; padding-left: 1.1rem; border-left: 3px solid #F5A623;">
          Diese Reibung kostet genau die Zeit, die im Mandat zählt — während die eigentliche Arbeit liegen bleibt.
        </li>
      </ul>
      <p style="font-size: 1.0625rem; color: #0B1528; margin: 0; line-height: 1.75; font-weight: 600; text-align: center;">
        Nicht Einzelaktionen — <span style="color: #F5A623;">Strukturen mit Wiederholbarkeit</span>. Genau das fehlt im Mandat.
      </p>
    </div>
  </section>

  <!-- 3. Über Marcus — Operator-Herkunft als Vertrauensanker (UM-06) -->
  <section style="background-color: #F9F7F7; padding: 4rem 1rem;">
    <div style="max-width: 56rem; margin: 0 auto;">
      <div style="display: flex; flex-wrap: wrap; gap: 2.5rem; align-items: center;">

        <img
          src="/marcus.jpg"
          alt="Marcus Eichler — KI-Architekt und Ex-Operator"
          style="width: 120px; height: 120px; border-radius: 9999px; object-fit: cover; border: 3px solid #F5A623; flex-shrink: 0;"
        />

        <div style="flex: 1; min-width: 260px;">
          <p style="font-size: 0.875rem; font-weight: 700; color: #F5A623; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.25rem;">
            Ich bin Marcus
          </p>
          <h2 style="font-size: 1.5rem; font-weight: 800; color: #0B1528; margin-bottom: 0.75rem;">
            KI-Architekt — und selbst Operator.
          </h2>
          <p style="font-size: 1rem; color: #374151; line-height: 1.7; margin-bottom: 1rem;">
            Kein Kurs, kein Video-Paket. Keine Agentur, die dich von einer Black Box
            abhängig macht. Ich bin <strong style="color: #0B1528;">KI-Architekt und selbst
            Operator</strong>: 29 Jahre Führung, ein CEO-Exit, über 1 Mrd. Euro Impact bei
            Telefónica. Ich kenne den Druck im Mandat aus eigener Erfahrung — und befähige
            dich, dir die KI-Werkzeuge, die genau dort liefern, selbst zu bauen. Du verstehst
            jeden Schritt und führst das System nach dem Mandat ohne mich weiter.
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
            <span style="background-color: rgba(11,21,40,0.07); color: #374151; padding: 0.15rem 0.6rem; border-radius: 9999px; font-size: 0.8125rem;">29 Jahre Führungserfahrung</span>
            <span style="background-color: rgba(11,21,40,0.07); color: #374151; padding: 0.15rem 0.6rem; border-radius: 9999px; font-size: 0.8125rem;">CEO-Exit MyDisplays</span>
            <span style="background-color: rgba(11,21,40,0.07); color: #374151; padding: 0.15rem 0.6rem; border-radius: 9999px; font-size: 0.8125rem;">&gt;1 Mrd. Euro · Telefónica</span>
          </div>
          <a
            href="/ueber-mich"
            style="display: inline-block; margin-top: 1rem; font-size: 0.9375rem; font-weight: 600; color: #F5A623; text-decoration: none;"
          >
            Mehr über Marcus →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. So läuft die Zusammenarbeit — 3 Schritte (IM, kein Preis) -->
  <section style="background-color: #FFFFFF; padding: 4rem 1rem;">
    <div style="max-width: 56rem; margin: 0 auto; text-align: center;">
      <h2 style="font-size: 1.875rem; font-weight: 800; color: #0B1528; margin-bottom: 2.5rem;">
        So läuft die Zusammenarbeit
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; text-align: left;">

        <div style="position: relative; padding-left: 1rem;">
          <div style="width: 2.5rem; height: 2.5rem; background-color: #F5A623; border-radius: 9999px; display: flex; align-items: center; justify-content: center; font-weight: 800; color: #000; margin-bottom: 1rem;">1</div>
          <h3 style="font-weight: 700; color: #0B1528; margin-bottom: 0.5rem;">Erstgespräch</h3>
          <p style="font-size: 0.9375rem; color: #6B7280; line-height: 1.5;">
            20 Minuten, kostenlos. Wir klären, welche KI-Anwendung in deinem Mandat heute den größten Hebel hat.
          </p>
        </div>

        <div style="position: relative; padding-left: 1rem;">
          <div style="width: 2.5rem; height: 2.5rem; background-color: #F5A623; border-radius: 9999px; display: flex; align-items: center; justify-content: center; font-weight: 800; color: #000; margin-bottom: 1rem;">2</div>
          <h3 style="font-weight: 700; color: #0B1528; margin-bottom: 0.5rem;">KI, die in dein Mandat passt</h3>
          <p style="font-size: 0.9375rem; color: #6B7280; line-height: 1.5;">
            In Tagen statt Monaten — angeleitet baust du sie dir selbst auf deiner eigenen Seite, nie in deinem Kundensystem. Nichts Sensibles verlässt deinen Auftrag.
          </p>
        </div>

        <div style="position: relative; padding-left: 1rem;">
          <div style="width: 2.5rem; height: 2.5rem; background-color: #F5A623; border-radius: 9999px; display: flex; align-items: center; justify-content: center; font-weight: 800; color: #000; margin-bottom: 1rem;">3</div>
          <h3 style="font-weight: 700; color: #0B1528; margin-bottom: 0.5rem;">Es läuft — und gehört dir</h3>
          <p style="font-size: 0.9375rem; color: #6B7280; line-height: 1.5;">
            Du lieferst sichtbar, dein Tagessatz trägt — und du führst das System nach dem Mandat ohne mich weiter.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- 4b. Kompakter Anker-Router (WP-04: ersetzt die frühere doppelte Mandatsphasen-Sektion) -->
  <section style="background-color: #FFFFFF; padding: 3.5rem 1rem 0;">
    <div style="max-width: 56rem; margin: 0 auto; text-align: center;">
      <p style="font-size: 0.8125rem; font-weight: 700; color: #F5A623; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 0.9rem;">
        Wo stehst du gerade? Der Weg hängt von deiner Mandatsphase ab — nie vom Budget.
      </p>
      <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem 1.5rem;">
        {
          weiche.map((w) => (
            <a href={w.href} style="font-size: 1rem; text-decoration: none;">
              <strong style="color: #0B1528;">{w.status}</strong>
              <span style="color: #9CA3AF;"> → </span>
              <span style="color: #F5A623; font-weight: 700;">{w.cta}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 5. Value-Ladder (UM-04) — zwei Wege (Kickstart vs. Werkstatt); App = Add-on (5b) -->
  <OfferCards />

  <!-- 5b. App als Zugabe zum Kurs (MP-05) — kein Preis-Tier, Add-on, CTA = Erstgespräch -->
  <section style="background-color: #F9F7F7; padding: 4rem 1rem;">
    <div style="max-width: 56rem; margin: 0 auto;">
      <div style="display: flex; flex-wrap: wrap; gap: 2.5rem; align-items: center;">
        <div style="flex: 1; min-width: 260px;">
          <p style="font-size: 0.8125rem; font-weight: 700; color: #F5A623; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 0.5rem;">
            Zugabe zum Kurs
          </p>
          <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; color: #0B1528; line-height: 1.2; margin: 0 0 1rem;">
            Die Interims-Magnet App hält dein System am Laufen.
          </h2>
          <p style="font-size: 1rem; color: #374151; line-height: 1.7; margin: 0 0 1rem;">
            Kein Standalone-Produkt, kein Done-for-you: Die App ist eine Zugabe zu deinem
            Kurs. Sie unterstützt dich beim Betrieb des Systems, das du dir selbst gebaut
            hast — deine Sichtbarkeits- und Pipeline-Maschine läuft weiter, auch wenn das
            nächste Mandat dich schon einspannt.
          </p>
          <p style="font-size: 0.9375rem; color: #6B7280; line-height: 1.6; margin: 0 0 1rem;">
            Die ersten <strong style="color: #0B1528;">6 Monate sind zum Kurs inklusive</strong>,
            danach läuft nur die App als monatliches, jederzeit kündbares Abo weiter. Dein
            Kickstart- bzw. Werkstatt-Ergebnis <strong style="color: #0B1528;">gehört dir ohne Abo</strong> —
            die App hält es nur bequem am Laufen.
          </p>
          <p style="font-size: 0.875rem; color: #6B7280; line-height: 1.6; margin: 0 0 1.5rem; font-style: italic;">
            Und die „für-dich-gebaut"-Premium-Variante? Nur in Ausnahmen — beim Selberbauen
            entsteht die Unabhängigkeit, die den eigentlichen Wert ausmacht.
          </p>
          <a href="/buchen" style="display: inline-block; background: #F5A623; color: #0B1528; font-weight: 700; font-size: 1rem; padding: 0.85rem 1.9rem; border-radius: 0.5rem; text-decoration: none;">
            Kostenloses Erstgespräch buchen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Lebender Beweis (UM-06 Rahmung in KiBeweis.astro) -->
  <KiBeweis />

  <!-- 8. Garantie — IM-Umsetzungs-Garantie (UM-06; 🔴 Wortlaut UM-10) -->
  <section style="background: #FFFFFF; overflow: hidden;">
    <div style="max-width: 56rem; margin: 0 auto; display: flex; flex-wrap: wrap; min-height: 220px;">

      <div style="background: #0B1528; flex: 1; min-width: 220px; padding: 2.5rem 2rem; display: flex; flex-direction: column; justify-content: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;" aria-hidden="true">🛡️</div>
        <h2 style="font-size: 1.25rem; font-weight: 800; color: #FFFFFF; margin-bottom: 0.75rem; line-height: 1.3;">
          Meine Umsetzungs-Garantie
        </h2>
        <p style="font-size: 0.9375rem; color: #9CA3AF; line-height: 1.6; margin: 0;">
          Wir bleiben dran,<br />
          bis dein erster KI-Prozess<br />wirklich läuft.
        </p>
      </div>

      <div style="flex: 1.4; min-width: 260px; padding: 2.5rem 2rem; background: #FFFFFF; border: 1px solid #E5E7EB; border-left: none;">
        <p style="font-size: 0.9375rem; color: #374151; line-height: 1.7; margin: 0;">
          {GARANTIE_KERN}
        </p>
      </div>
    </div>
  </section>

  <!-- 8b. FAQ (WP-09) — sichtbare Q&A passend zum FAQPage-JSON-LD -->
  <section style="background-color: #F9F7F7; padding: 4rem 1rem;" id="faq">
    <div style="max-width: 42rem; margin: 0 auto;">
      <h2 style="font-size: 1.875rem; font-weight: 800; color: #0B1528; text-align: center; margin: 0 0 2rem;">
        Häufige Fragen
      </h2>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        {
          faqs.map((faq) => (
            <details style="border-radius: 0.75rem; border: 1px solid #E5E7EB; background: #FFFFFF; padding: 1.25rem;">
              <summary style="cursor: pointer; font-weight: 700; color: #0B1528; list-style: none;">
                {faq.question}
              </summary>
              <p style="margin: 0.75rem 0 0; color: #374151; line-height: 1.7; font-size: 0.9375rem;">
                {faq.answer}
              </p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 9. Final-CTA (Erstgespräch, kein Preis/Stripe) -->
  <section style="background-color: #0B1528; padding: 4rem 1rem; text-align: center;">
    <div style="max-width: 42rem; margin: 0 auto;">
      <h2 style="font-size: 2rem; font-weight: 800; color: #FFFFFF; margin-bottom: 0.75rem;">
        Lass uns auf dein nächstes Mandat schauen.
      </h2>
      <p style="font-size: 1rem; color: #D1D5DB; margin-bottom: 2rem; line-height: 1.6;">
        20 Minuten, kostenlos. Wir klären, welcher Weg zu deiner Mandatsphase passt — und wo KI bei dir den größten Hebel hat.
      </p>
      <a
        href="/buchen"
        style="display: inline-block; background-color: #F5A623; color: #000000; font-weight: 700; padding: 1rem 2.5rem; border-radius: 0.5rem; text-decoration: none; font-size: 1.0625rem;"
      >
        Kostenloses Erstgespräch buchen
      </a>
      <p style="margin-top: 1rem; font-size: 0.875rem; color: #9CA3AF;">
        Kostenlos · unverbindlich
      </p>
    </div>
  </section>

  <!-- FAQPage JSON-LD (nur Startseiten-Fragen, kein Preis) -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

</Base>
