---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import OfferCards from "../components/OfferCards.astro";
import KiBeweis from "../components/KiBeweis.astro";

// IM-Pivot (Modell B): Startseite für solo Operations-/COO-Interim-Manager.
// Leitplanken: kein oeffentlicher Preis, kein Stripe, kein Coaching-Jargon; ein Hero-Versprechen; alle CTAs → /buchen.
// Segmentierung nach Mandatsphase, nie nach Preis. Garantie = Prozess-/Lauf-Garantie (🔴 Wortlaut UM-10).

// UM-05 — Segmentierungs-Weiche nach Mandatsstatus (Muster: routing-Grid der Werkstatt)
const weiche = [
  {
    status: "Zwischen Mandaten",
    text: "Die Pipeline ist leer, aber du hast Zeit. Du baust dir — begleitet — deinen eigenen Akquise-Magneten, damit das nächste Mandat von selbst anläuft.",
    cta: "Zur Werkstatt →",
    href: "/werkstatt",
  },
  {
    status: "Im oder vor dem Mandat",
    text: "Akuter KI- und Tagessatz-Druck. Ich baue dir KI-Werkzeuge auf deiner eigenen Seite, die in deinem laufenden Mandat sofort liefern.",
    cta: "Zum Mandats-Kickstart →",
    href: "/kickstart",
  },
  {
    status: "Stabiles Mandat, denkst ans nächste",
    text: "Du hast Honorar, aber keine Hand frei. Ich baue dein System done-for-you — zahlbar erst beim Anschlussmandat.",
    cta: "Erstgespräch →",
    href: "/buchen",
  },
];
---

<Base
  title="KI-Systeme für solo Interim-Manager (Operations & COO) | Value Lift AI"
  description="Das KI-System für solo Operations-/COO-Interim-Manager im DACH-Raum: im Mandat sichtbar liefern und die Pipeline warmhalten, während du im Einsatz bist. Kostenloses Erstgespräch, kein Pitch."
  path="/"
>

  <!-- 1. Hero (UM-03) -->
  <Hero />

  <!-- 2. Avatar-Resonanz: Akquise-Paradox + KI-Pflicht im Mandat (UM-03) -->
  <section style="background-color: #FFFFFF; padding: 4rem 1rem;">
    <div style="max-width: 48rem; margin: 0 auto;">
      <h2 style="font-size: 1.875rem; font-weight: 800; color: #0B1528; margin-bottom: 1.75rem; text-align: center; line-height: 1.25;">
        Das Akquise-Paradox: Du gewinnst dein nächstes Mandat nicht <em>nach</em> dem aktuellen — sondern <em>währenddessen</em>.
      </h2>
      <ul style="list-style: none; padding: 0; margin: 0 0 1.75rem; display: flex; flex-direction: column; gap: 1rem;">
        <li style="font-size: 1.0625rem; color: #374151; line-height: 1.7; padding-left: 1.1rem; border-left: 3px solid #F5A623;">
          <strong style="color: #0B1528;">Mandat endet, Pipeline kalt.</strong> Im Einsatz zwölf Stunden am Tag, keine Zeit für Sichtbarkeit. Dann ist Schluss — und du fängst bei null an, genau wenn du am wenigsten verhandeln kannst.
        </li>
        <li style="font-size: 1.0625rem; color: #374151; line-height: 1.7; padding-left: 1.1rem; border-left: 3px solid #F5A623;">
          <strong style="color: #0B1528;">Die KI-Erwartung sitzt dir im Nacken.</strong> Auftraggeber wollen jemanden, der KI sichtbar in die Operations bringt. Du hast Tools ausprobiert. Aber „ausprobiert" ist kein System — die Lücke schließt du neben der Mandatslast nie allein.
        </li>
        <li style="font-size: 1.0625rem; color: #374151; line-height: 1.7; padding-left: 1.1rem; border-left: 3px solid #F5A623;">
          <strong style="color: #0B1528;">Sichtbarkeit nur bei freier Zeit ist keine Pipeline.</strong> Sie ist ein Hobby.
        </li>
      </ul>
      <p style="font-size: 1.0625rem; color: #0B1528; margin: 0; line-height: 1.75; font-weight: 600; text-align: center;">
        Ein KI-System, das dich sichtbar hält und deine Beziehungen warm — während du lieferst. Das ist der Unterschied zwischen „ich suche wieder" und „das Nächste läuft schon an".
      </p>
    </div>
  </section>

  <!-- 3. Über Marcus — Operator-Herkunft als Vertrauensanker (UM-06) -->
  <section style="background-color: #F9F7F7; padding: 4rem 1rem;">
    <div style="max-width: 56rem; margin: 0 auto;">
      <div style="display: flex; flex-wrap: wrap; gap: 2.5rem; align-items: center;">

        <img
          src="/marcus.jpg"
          alt="Marcus Eichler — KI-Architekt und Ex-Operator"
          style="width: 120px; height: 120px; border-radius: 9999px; object-fit: cover; border: 3px solid #F5A623; flex-shrink: 0;"
        />

        <div style="flex: 1; min-width: 260px;">
          <p style="font-size: 0.875rem; font-weight: 700; color: #F5A623; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.25rem;">
            Ich bin Marcus
          </p>
          <h2 style="font-size: 1.5rem; font-weight: 800; color: #0B1528; margin-bottom: 0.75rem;">
            KI-Architekt — und selbst Operator.
          </h2>
          <p style="font-size: 1rem; color: #374151; line-height: 1.7; margin-bottom: 1rem;">
            Kein Kurs, kein Video-Paket. Keine Agentur, die dich von einer Black Box
            abhängig macht. Ich bin <strong style="color: #0B1528;">KI-Architekt und selbst
            Operator</strong>: 29 Jahre Führung, ein CEO-Exit, über 1 Mrd. Euro Impact bei
            Telefónica. Ich kenne den Druck im Mandat aus eigener Erfahrung — und baue
            dir die KI-Werkzeuge, die genau dort liefern. Du verstehst jeden Schritt und
            führst das System nach dem Mandat ohne mich weiter.
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
            <span style="background-color: rgba(11,21,40,0.07); color: #374151; padding: 0.15rem 0.6rem; border-radius: 9999px; font-size: 0.8125rem;">29 Jahre Führungserfahrung</span>
            <span style="background-color: rgba(11,21,40,0.07); color: #374151; padding: 0.15rem 0.6rem; border-radius: 9999px; font-size: 0.8125rem;">CEO-Exit MyDisplays</span>
            <span style="background-color: rgba(11,21,40,0.07); color: #374151; padding: 0.15rem 0.6rem; border-radius: 9999px; font-size: 0.8125rem;">&gt;1 Mrd. Euro · Telefónica</span>
          </div>
          <a
            href="/ueber-mich"
            style="display: inline-block; margin-top: 1rem; font-size: 0.9375rem; font-weight: 600; color: #F5A623; text-decoration: none;"
          >
            Mehr über Marcus →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. So läuft die Zusammenarbeit — 3 Schritte (IM, kein Preis) -->
  <section style="background-color: #FFFFFF; padding: 4rem 1rem;">
    <div style="max-width: 56rem; margin: 0 auto; text-align: center;">
      <h2 style="font-size: 1.875rem; font-weight: 800; color: #0B1528; margin-bottom: 2.5rem;">
        So läuft die Zusammenarbeit
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; text-align: left;">

        <div style="position: relative; padding-left: 1rem;">
          <div style="width: 2.5rem; height: 2.5rem; background-color: #F5A623; border-radius: 9999px; display: flex; align-items: center; justify-content: center; font-weight: 800; color: #000; margin-bottom: 1rem;">1</div>
          <h3 style="font-weight: 700; color: #0B1528; margin-bottom: 0.5rem;">Erstgespräch</h3>
          <p style="font-size: 0.9375rem; color: #6B7280; line-height: 1.5;">
            20 Minuten, kostenlos. Wir klären, welche KI-Anwendung in deinem Mandat heute den größten Hebel hat.
          </p>
        </div>

        <div style="position: relative; padding-left: 1rem;">
          <div style="width: 2.5rem; height: 2.5rem; background-color: #F5A623; border-radius: 9999px; display: flex; align-items: center; justify-content: center; font-weight: 800; color: #000; margin-bottom: 1rem;">2</div>
          <h3 style="font-weight: 700; color: #0B1528; margin-bottom: 0.5rem;">Ich baue in dein Mandat</h3>
          <p style="font-size: 0.9375rem; color: #6B7280; line-height: 1.5;">
            In Tagen statt Monaten — auf meiner Seite, nie in deinem Kundensystem. Nichts Sensibles verlässt deinen Auftrag.
          </p>
        </div>

        <div style="position: relative; padding-left: 1rem;">
          <div style="width: 2.5rem; height: 2.5rem; background-color: #F5A623; border-radius: 9999px; display: flex; align-items: center; justify-content: center; font-weight: 800; color: #000; margin-bottom: 1rem;">3</div>
          <h3 style="font-weight: 700; color: #0B1528; margin-bottom: 0.5rem;">Es läuft — und gehört dir</h3>
          <p style="font-size: 0.9375rem; color: #6B7280; line-height: 1.5;">
            Du lieferst sichtbar, dein Tagessatz trägt — und du führst das System nach dem Mandat ohne mich weiter.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- 5. Value-Ladder (UM-04) -->
  <OfferCards />

  <!-- 6. Segmentierungs-Weiche nach Mandatsstatus (UM-05) -->
  <section style="background-color: #FFFFFF; padding: 4rem 1rem;">
    <div style="max-width: 64rem; margin: 0 auto;">
      <div style="max-width: 42rem; margin: 0 auto 2.5rem; text-align: center;">
        <h2 style="font-size: 1.875rem; font-weight: 800; color: #0B1528; margin-bottom: 0.75rem;">
          Wo stehst du gerade?
        </h2>
        <p style="font-size: 1.0625rem; color: #6B7280; line-height: 1.6;">
          Der richtige Weg hängt von deiner Mandatsphase ab — nie vom Budget.
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
        {
          weiche.map((w) => (
            <article style="display: flex; flex-direction: column; border-radius: 1rem; border: 1px solid #E5E7EB; background-color: #F9F7F7; padding: 1.5rem;">
              <p style="font-size: 0.8125rem; font-weight: 700; color: #F5A623; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 0.5rem;">
                {w.status}
              </p>
              <p style="font-size: 0.9375rem; color: #374151; line-height: 1.6; flex: 1; margin: 0 0 1rem;">
                {w.text}
              </p>
              <a href={w.href} style="font-size: 0.9375rem; font-weight: 700; color: #0B1528; text-decoration: underline; text-underline-offset: 3px;">
                {w.cta}
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 7. Lebender Beweis (UM-06 Rahmung in KiBeweis.astro) -->
  <KiBeweis />

  <!-- 8. Garantie — IM-Prozess-/Lauf-Garantie (UM-06; 🔴 Wortlaut UM-10) -->
  <section style="background: #FFFFFF; overflow: hidden;">
    <div style="max-width: 56rem; margin: 0 auto; display: flex; flex-wrap: wrap; min-height: 220px;">

      <div style="background: #0B1528; flex: 1; min-width: 220px; padding: 2.5rem 2rem; display: flex; flex-direction: column; justify-content: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;" aria-hidden="true">🛡️</div>
        <h2 style="font-size: 1.25rem; font-weight: 800; color: #FFFFFF; margin-bottom: 0.75rem; line-height: 1.3;">
          Meine Lauf-Garantie
        </h2>
        <p style="font-size: 0.9375rem; color: #9CA3AF; line-height: 1.6; margin: 0;">
          Das Risiko liegt bei mir.<br />
          Du bekommst ein System, das läuft —<br />nicht bloß Versuche.
        </p>
      </div>

      <div style="flex: 1.4; min-width: 260px; padding: 2.5rem 2rem; background: #FFFFFF; border: 1px solid #E5E7EB; border-left: none;">
        <p style="font-size: 0.9375rem; color: #374151; line-height: 1.7; margin: 0;">
          Wenn die im Mandats-Kickstart aufgebauten KI-Werkzeuge bei Übergabe nicht wie
          vereinbart funktionieren, arbeite ich
          <strong style="color: #0B1528;">innerhalb von 4 Wochen nach Übergabe</strong>
          kostenlos nach, bis sie die
          <strong style="color: #0B1528;">vorab gemeinsam definierten Funktionskriterien</strong>
          erfüllen. Voraussetzung ist deine <strong style="color: #0B1528;">Mitwirkung</strong>
          (Zugang zu den vereinbarten Eingaben und Daten). Das ist eine Prozess-Garantie
          auf die Funktion der Werkzeuge — keine Zusage auf ein konkretes Mandat, einen
          bestimmten Umsatz oder eine Reichweite.
        </p>
      </div>
    </div>
  </section>

  <!-- 9. Final-CTA (Erstgespräch, kein Preis/Stripe) -->
  <section style="background-color: #0B1528; padding: 4rem 1rem; text-align: center;">
    <div style="max-width: 42rem; margin: 0 auto;">
      <h2 style="font-size: 2rem; font-weight: 800; color: #FFFFFF; margin-bottom: 0.75rem;">
        Lass uns auf dein nächstes Mandat schauen.
      </h2>
      <p style="font-size: 1rem; color: #D1D5DB; margin-bottom: 2rem; line-height: 1.6;">
        20 Minuten, kostenlos. Wir klären, welcher Weg zu deiner Mandatsphase passt — und wo KI bei dir den größten Hebel hat.
      </p>
      <a
        href="/buchen"
        style="display: inline-block; background-color: #F5A623; color: #000000; font-weight: 700; padding: 1rem 2.5rem; border-radius: 0.5rem; text-decoration: none; font-size: 1.0625rem;"
      >
        Erstgespräch vereinbaren
      </a>
      <p style="margin-top: 1rem; font-size: 0.875rem; color: #9CA3AF;">
        Kostenlos · unverbindlich
      </p>
    </div>
  </section>

</Base>
