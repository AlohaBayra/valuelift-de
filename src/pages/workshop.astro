---
import LandingPage from "../layouts/LandingPage.astro";

const agenda = [
  {
    time: "Vormittag",
    title: "Prozess auseinandernehmen",
    text: "Wir nehmen deinen gewählten Prozess komplett auseinander und identifizieren, wo KI den größten Hebel hat.",
  },
  {
    time: "Mittag",
    title: "Workflow bauen",
    text: "Wir bauen den KI-Workflow Schritt für Schritt gemeinsam auf — du sitzt am Steuer, wir navigieren.",
  },
  {
    time: "Nachmittag",
    title: "Testen & übergeben",
    text: "Wir testen den Workflow an echten Fällen, feilen nach und sorgen dafür, dass du ihn allein bedienen kannst.",
  },
];
---

<LandingPage
  title="KI-Sprint Workshop-Tag — Dein vollständiger KI-Workflow an einem Tag"
  description="Ein 1:1-Tag mit Marcus Eichler: Gemeinsam bauen wir einen vollständigen KI-Workflow für einen Prozess deiner Wahl. Preis auf Anfrage."
  path="/workshop"
>
  <section class="bg-brand-dark text-brand-white">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 sm:py-24">
      <span
        class="mb-6 inline-block rounded-full border border-brand-blue bg-brand-blue/10 px-4 py-1 text-sm font-semibold text-brand-blueLight"
      >
        KI-Sprint · 1 Tag · 1:1 mit Marcus
      </span>
      <h1 class="text-balance text-4xl font-extrabold leading-tight sm:text-5xl">
        Ein Tag. Ein vollständiger KI-Workflow. Deiner.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300">
        Im KI-Sprint arbeiten wir einen ganzen Tag 1:1 zusammen und bauen einen
        vollständigen KI-Workflow für einen Prozess, den du selbst wählst. Am
        Ende läuft er — und du verstehst jeden Schritt.
      </p>
      <div class="mt-10">
        <a
          href="/buchen"
          class="inline-block rounded-lg bg-brand-blue px-8 py-4 font-bold text-brand-black shadow-lg hover:bg-brand-blueLight"
        >
          Termin anfragen
        </a>
        <p class="mt-3 text-sm text-gray-400">Preis auf Anfrage</p>
      </div>
    </div>
  </section>

  <!-- Für wen -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="text-3xl font-extrabold">Für wen der KI-Sprint gemacht ist</h2>
      <p class="mt-4 text-lg text-brand-gray">
        Für Berater:innen und Coaches, die nicht nur herumprobieren, sondern
        einen echten Prozess automatisieren wollen — Angebotserstellung,
        Content-Produktion, Onboarding, Recherche oder was auch immer dich am
        meisten Zeit kostet.
      </p>
    </div>
  </section>

  <!-- Tagesablauf -->
  <section class="bg-brand-lightBg py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="text-center text-3xl font-extrabold">So sieht der Tag aus</h2>
      <div class="mt-10 space-y-6">
        {
          agenda.map((block) => (
            <article class="flex flex-col gap-2 rounded-2xl border border-gray-200 bg-brand-white p-6 sm:flex-row sm:items-start sm:gap-6">
              <div class="w-32 shrink-0 font-bold text-brand-blue">{block.time}</div>
              <div>
                <h3 class="text-lg font-bold">{block.title}</h3>
                <p class="mt-1 text-sm text-brand-gray">{block.text}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Garantie -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 text-center sm:px-6">
      <div class="text-5xl">🛡️</div>
      <h2 class="mt-4 text-3xl font-extrabold">Die Garantie</h2>
      <p class="mt-4 text-lg text-brand-gray">
        Der Workflow läuft nach unserem gemeinsamen Tag — oder ich arbeite
        kostenlos nach, bis er läuft.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-dark py-16 text-center text-brand-white sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <h2 class="text-3xl font-extrabold">Lass uns sprechen</h2>
      <p class="mt-4 text-lg text-gray-300">
        Im kostenlosen Erstgespräch klären wir deinen Prozess und ob der
        KI-Sprint zu dir passt.
      </p>
      <a
        href="/buchen"
        class="mt-8 inline-block rounded-lg bg-brand-blue px-8 py-4 font-bold text-brand-black hover:bg-brand-blueLight"
      >
        Termin anfragen
      </a>
      <p class="mt-6 text-sm text-gray-400">
        <a href="/" class="underline hover:text-brand-blueLight">← Zurück zur Startseite</a>
      </p>
    </div>
  </section>
</LandingPage>
