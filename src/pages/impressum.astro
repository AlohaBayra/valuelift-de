---
import Base from "../layouts/Base.astro";
---

<Base
  title="Impressum — Value Lift AI"
  description="Impressum von Value Lift AI / Marcus Eichler gemäß § 5 DDG."
  path="/impressum"
>
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h1 class="text-3xl font-extrabold sm:text-4xl">Impressum</h1>

      <div class="mt-8 space-y-8 text-brand-dark">

        <div>
          <h2 class="text-xl font-bold">Angaben gemäß § 5 DDG</h2>
          <p class="mt-2 text-brand-gray leading-relaxed">
            Marcus Eichler<br />
            Value Lift AI<br />
            Arberstraße 19<br />
            94428 Eichendorf<br />
            Deutschland
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold">Kontakt</h2>
          <p class="mt-2 text-brand-gray leading-relaxed">
            E-Mail: <a href="mailto:marcus.eichler@valuelift.de" class="underline">marcus.eichler@valuelift.de</a><br />
            Internet: <a href="https://www.valuelift.de" class="underline">https://www.valuelift.de</a>
          </p>
        </div>

