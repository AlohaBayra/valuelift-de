---
import Base from "../layouts/Base.astro";
---

<Base
  title="Impressum — Value Lift AI"
  description="Impressum von Value Lift AI / Marcus Eichler."
  path="/impressum"
>
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h1 class="text-3xl font-extrabold sm:text-4xl">Impressum</h1>

      <div class="mt-6 rounded-xl border border-brand-blue/40 bg-brand-lightBg p-4 text-sm text-brand-gray">
        <strong class="text-brand-dark">Platzhalter:</strong> Vor dem Go-Live durch
        die vollständigen, rechtsgültigen Pflichtangaben nach § 5 DDG (ehem. § 5
        TMG) ersetzen.
      </div>

      <div class="mt-8 space-y-6 text-brand-dark">
        <div>
          <h2 class="text-xl font-bold">Angaben gemäß § 5 DDG</h2>
          <p class="mt-2 text-brand-gray">
            Marcus Eichler<br />Value Lift AI<br />[Straße &amp; Hausnummer]<br />[PLZ
            Ort]
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold">Kontakt</h2>
          <p class="mt-2 text-brand-gray">
            E-Mail: [E-Mail-Adresse]<br />Telefon: [optional]
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold">Umsatzsteuer-ID</h2>
          <p class="mt-2 text-brand-gray">
            [USt-IdNr. gemäß § 27 a UStG, falls vorhanden]
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold">Verantwortlich für den Inhalt</h2>
          <p class="mt-2 text-brand-gray">Marcus Eichler, [Anschrift wie oben]</p>
        </div>
      </div>
    </div>
  </section>
</Base>
