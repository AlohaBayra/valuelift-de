---
import LandingPage from "../layouts/LandingPage.astro";
import FAQ from "../components/FAQ.astro";
import NextWorkshop from "../components/NextWorkshop.astro";

const includes = [
  "5 fertige LinkedIn-Posts, die zu dir passen",
  "Dein persönlicher KI-Baukasten zum Wiederverwenden",
  "Fertige Vorlagen für den Sofort-Einsatz",
  "Content-Kalender-Template",
  "Aufzeichnung der gesamten Session",
];

const steps = [
  {
    title: "Grundlagen, die zählen",
    text: "Keine Theorie-Schlacht. Wir klären in 20 Minuten, was du über KI wissen musst — und lassen den Rest weg.",
  },
  {
    title: "Wir bauen deinen KI-Baukasten",
    text: "Gemeinsam erstellen wir fertige Vorlagen, die zu deiner Stimme und deinem Geschäft passen.",
  },
  {
    title: "5 Posts zum Mitnehmen",
    text: "Am Ende hast du 5 fertige LinkedIn-Posts und einen KI-Baukasten, um beliebig viele weitere zu erstellen.",
  },
];
---

<LandingPage
  title="KI-Kickstart Bootcamp — Dein erster KI-Prozess in 2 Stunden (97€)"
  description="Live-Online-Bootcamp für Berater und Coaches. In 2 Stunden zu 5 LinkedIn-Posts, einem Prompt-System und einem Content-Kalender. Mit Geld-zurück-Garantie."
  path="/bootcamp"
  ogImage="https://valuelift.de/og-bootcamp.png"
>
  <!-- Hero -->
  <section class="bg-brand-dark text-brand-white">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 sm:py-24">
      <span
        class="mb-6 inline-block rounded-full border border-brand-blue bg-brand-blue/10 px-4 py-1 text-sm font-semibold text-brand-blueLight"
      >
        KI-Kickstart · Live-Online · 97€
      </span>
      <h1 class="text-balance text-4xl font-extrabold leading-tight sm:text-5xl">
        In 2 Stunden vom Zögern zum laufenden KI-Prozess.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300">
        Schluss mit Tutorials, die du nie zu Ende schaust. Im KI-Kickstart bauen
        wir live gemeinsam deinen ersten KI-Prozess — und du gehst mit 5 fertigen
        LinkedIn-Posts und einem wiederverwendbaren KI-Baukasten raus.
      </p>
      <!-- M13: Scarcity Banner -->
      <div class="mt-8 inline-flex items-center gap-2 rounded-full border border-brand-blue bg-brand-blue/10 px-5 py-2 text-sm font-semibold text-brand-blueLight">
        <span>📅</span>
        <NextWorkshop suffix=" · Plätze begrenzt" />
      </div>
      <div class="mt-4">
        <a
          href="https://buy.stripe.com/00wfZggVEcLs3DVfhi8bS05"
          target="_blank"
          rel="noopener"
          class="inline-block rounded-lg bg-brand-blue px-8 py-4 font-bold text-brand-black shadow-lg hover:bg-brand-blueLight"
        >
          Jetzt buchen — 97€
        </a>
        <p class="mt-3 text-sm text-gray-400">
          Geld-zurück-Garantie · max. 15 Teilnehmer
        </p>
      </div>
    </div>
  </section>

  <!-- Was du bekommst -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 class="text-center text-3xl font-extrabold">Das nimmst du mit</h2>
      <ul class="mt-8 space-y-4">
        {
          includes.map((item) => (
            <li class="flex items-start gap-3 rounded-xl bg-brand-lightBg p-4">
              <span class="mt-0.5 text-xl font-bold text-brand-blue">✓</span>
              <span class="text-base text-brand-dark">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ST21: Für wen ist das / für wen nicht -->
  <section style="background-color: #F9F7F7; padding: 3.5rem 1rem;">
    <div style="max-width: 42rem; margin: 0 auto;">
      <h2 style="font-size: 1.5rem; font-weight: 800; color: #0B1528; text-align: center; margin-bottom: 2rem;">
        Ist das KI-Kickstart das Richtige für dich?
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem;">

        <!-- Passt -->
        <div style="background: #FFFFFF; border-radius: 1rem; border: 2px solid rgba(34,197,94,0.4); padding: 1.5rem;">
          <p style="font-weight: 700; color: #16A34A; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem;">✓ Das passt zu dir</p>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem;">
            <li style="font-size: 0.9375rem; color: #374151; display: flex; gap: 0.5rem;"><span style="color: #16A34A; flex-shrink:0;">✓</span> Du arbeitest solo oder im kleinen Team</li>
            <li style="font-size: 0.9375rem; color: #374151; display: flex; gap: 0.5rem;"><span style="color: #16A34A; flex-shrink:0;">✓</span> Du verlierst Zeit mit repetitiven Aufgaben</li>
            <li style="font-size: 0.9375rem; color: #374151; display: flex; gap: 0.5rem;"><span style="color: #16A34A; flex-shrink:0;">✓</span> Du weißt, was KI kann — aber hast noch kein System</li>
            <li style="font-size: 0.9375rem; color: #374151; display: flex; gap: 0.5rem;"><span style="color: #16A34A; flex-shrink:0;">✓</span> Du willst in 2 Stunden ein Ergebnis, kein Wissen</li>
            <li style="font-size: 0.9375rem; color: #374151; display: flex; gap: 0.5rem;"><span style="color: #16A34A; flex-shrink:0;">✓</span> LinkedIn-Content kostet dich zu viel Zeit</li>
          </ul>
        </div>

        <!-- Passt nicht -->
        <div style="background: #FFFFFF; border-radius: 1rem; border: 2px solid rgba(239,68,68,0.3); padding: 1.5rem;">
          <p style="font-weight: 700; color: #DC2626; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem;">✗ Nicht das Richtige wenn</p>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem;">
            <li style="font-size: 0.9375rem; color: #374151; display: flex; gap: 0.5rem;"><span style="color: #DC2626; flex-shrink:0;">✗</span> Du bereits aktiv KI-Workflows nutzt</li>
            <li style="font-size: 0.9375rem; color: #374151; display: flex; gap: 0.5rem;"><span style="color: #DC2626; flex-shrink:0;">✗</span> Du nur technische Automatisierung suchst</li>
            <li style="font-size: 0.9375rem; color: #374151; display: flex; gap: 0.5rem;"><span style="color: #DC2626; flex-shrink:0;">✗</span> Du kein LinkedIn nutzt und auch nicht willst</li>
          </ul>
          <p style="margin-top: 1rem; font-size: 0.875rem; color: #6B7280;">
            → Dann passt der <a href="/workshop" style="color: #F5A623; text-decoration: none; font-weight: 600;">KI-Sprint</a> oder das <a href="/system" style="color: #F5A623; text-decoration: none; font-weight: 600;">KI-Komplettsystem</a> besser.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Ablauf -->
  <section class="bg-brand-lightBg py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="text-center text-3xl font-extrabold">So laufen die 2 Stunden ab</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {
          steps.map((step, i) => (
            <article class="rounded-2xl border border-gray-200 bg-brand-white p-6">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-blue font-bold text-brand-black">
                {i + 1}
              </div>
              <h3 class="mt-4 text-lg font-bold">{step.title}</h3>
              <p class="mt-2 text-base text-brand-gray">{step.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Garantie -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 text-center sm:px-6">
      <div class="text-5xl">🛡️</div>
      <h2 class="mt-4 text-3xl font-extrabold">Die Garantie</h2>
      <p class="mt-4 text-lg text-brand-gray">
        Dein erster KI-Prozess läuft nach 2 Stunden — oder du bekommst deine 97€
        vollständig zurück. Das Risiko trage ich, nicht du.
      </p>
    </div>
  </section>

  <FAQ />

  <!-- Abschluss-CTA -->
  <section class="bg-brand-dark py-16 text-center text-brand-white sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <h2 class="text-3xl font-extrabold">Sichere dir deinen Platz</h2>
      <p class="mt-4 text-lg text-gray-300">
        97€ · 2 Stunden · max. 15 Teilnehmer · mit Geld-zurück-Garantie.
      </p>
      <a
        href="https://buy.stripe.com/00wfZggVEcLs3DVfhi8bS05"
        target="_blank"
        rel="noopener"
        class="mt-8 inline-block rounded-lg bg-brand-blue px-8 py-4 font-bold text-brand-black hover:bg-brand-blueLight"
      >
        KI-Kickstart buchen — 97€
      </a>
      <p class="mt-6 text-sm text-gray-400">
        <a href="/" class="underline hover:text-brand-blueLight">← Zurück zur Startseite</a>
      </p>
    </div>
  </section>
</LandingPage>
