---
import Base from "../layouts/Base.astro";
import Testimonials from "../components/Testimonials.astro";

const stats = [
  { value: "2 Std.", label: "bis zum ersten laufenden System" },
  { value: "100%", label: "Geld-zurück-Garantie im Bootcamp" },
  { value: "DACH", label: "Berater, Coaches & Dienstleister" },
];

const cases = [
  {
    title: "Vom leeren Blatt zu 5 Posts",
    text: "Eine Beraterin startete ohne Content-Routine. Nach dem KI-Kickstart hatte sie ein Prompt-System und 5 fertige LinkedIn-Posts — und postet seitdem regelmäßig.",
    result: "Ergebnis: konsistenter Content statt Funkstille.",
  },
  {
    title: "Angebotserstellung halbiert",
    text: "Ein Coach automatisierte im KI-Sprint seinen Angebotsprozess. Was vorher Stunden dauerte, läuft jetzt in einem geführten Workflow.",
    result: "Ergebnis: deutlich weniger Zeit pro Angebot.",
  },
  {
    title: "Drei Prozesse, ein System",
    text: "Ein Dienstleister verband im KI-Komplettsystem Recherche, Content und Reporting zu einem zusammenhängenden System.",
    result: "Ergebnis: weniger Tool-Chaos, mehr Fokus.",
  },
];
---

<Base
  title="Ergebnisse — Testimonials & Case Studies | Value Lift AI"
  description="Stimmen und Fallbeispiele von Berater:innen und Coaches, die mit Value Lift AI ihren ersten KI-Prozess gebaut haben."
  path="/ergebnisse"
>
  <section class="bg-brand-dark text-brand-white">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 sm:py-20">
      <h1 class="text-4xl font-extrabold sm:text-5xl">Ergebnisse, die zählen</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-300">
        KI ist kein Selbstzweck. Hier zeigt sich, was bei Berater:innen und
        Coaches tatsächlich ankommt.
      </p>

      <div class="mt-12 grid gap-8 sm:grid-cols-3">
        {
          stats.map((s) => (
            <div>
              <div class="text-4xl font-extrabold text-brand-blueLight">{s.value}</div>
              <div class="mt-1 text-sm text-gray-300">{s.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="bg-brand-white py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 class="text-center text-3xl font-extrabold">Beispiele aus der Praxis</h2>
      <p class="mt-3 text-center text-sm text-brand-gray">
        (Anonymisierte Platzhalter — echte Fälle folgen.)
      </p>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {
          cases.map((c) => (
            <article class="flex flex-col rounded-2xl border border-gray-200 bg-brand-lightBg p-6">
              <h3 class="text-lg font-bold">{c.title}</h3>
              <p class="mt-2 flex-1 text-sm text-brand-gray">{c.text}</p>
              <p class="mt-4 text-sm font-bold text-brand-blue">{c.result}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <Testimonials />

  <!-- CTA -->
  <section class="bg-brand-dark py-16 text-center text-brand-white sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <h2 class="text-3xl font-extrabold">Werde das nächste Ergebnis</h2>
      <p class="mt-4 text-lg text-gray-300">
        Starte mit dem KI-Kickstart oder buche ein kostenloses Erstgespräch.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/bootcamp"
          class="w-full rounded-lg bg-brand-blue px-8 py-4 font-bold text-brand-black hover:bg-brand-blueLight sm:w-auto"
        >
          KI-Kickstart buchen — 97€
        </a>
        <a
          href="/buchen"
          class="font-semibold text-brand-white underline-offset-4 hover:text-brand-blueLight hover:underline"
        >
          Termin buchen →
        </a>
      </div>
    </div>
  </section>
</Base>
