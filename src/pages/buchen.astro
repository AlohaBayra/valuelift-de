---
import Base from "../layouts/Base.astro";

const tidycalPath = "marcuseichler/kennenlerngesprach-mit-marcus-eichler-1wr7yd6";
const tidycalUrl = `https://tidycal.com/${tidycalPath}`;
---

<Base
  title="Termin buchen — Kostenloses Erstgespräch mit Marcus Eichler"
  description="Buche dein kostenloses Erstgespräch mit Marcus Eichler von Value Lift AI. 20 Minuten, kostenlos, ohne Pitch."
  path="/buchen"
>
  <!-- Hero-Bereich -->
  <section class="bg-brand-dark text-brand-white">
    <div class="mx-auto max-w-3xl px-4 py-14 text-center sm:px-6">
      <h1 class="text-4xl font-extrabold sm:text-5xl">Termin buchen</h1>
      <p class="mx-auto mt-4 max-w-xl text-lg text-gray-300">
        20 Minuten, kostenlos, ohne Pitch. Wir klären gemeinsam, ob und wie ich dir helfen kann.
      </p>
    </div>
  </section>

  <!-- TidyCal Inline-Embed (kein iframe, kein eigener Scroll) -->
  <section class="bg-brand-lightBg py-10 sm:py-14">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">

      <div class="tidycal-embed" data-path={tidycalPath}></div>
      <script src="https://asset-tidycal.b-cdn.net/js/embed.js" async></script>

      <p class="mt-8 text-center text-sm text-brand-gray">
        Kalender lädt nicht?{" "}
        <a
          href={tidycalUrl}
          class="font-semibold text-brand-blue underline hover:text-brand-blueLight"
          target="_blank"
          rel="noopener"
        >
          Direkt bei TidyCal buchen →
        </a>
      </p>
    </div>
  </section>
</Base>
