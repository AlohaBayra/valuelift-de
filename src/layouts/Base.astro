---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
  /** Wenn true, wird die globale Navigation ausgeblendet (für Landingpages). */
  hideNav?: boolean;
  /** Pfad relativ zur Domain, z.B. "/bootcamp" — für Canonical & OG-URL. */
  path?: string;
}

const {
  title = "Value Lift AI — KI-Prozesse für Berater & Coaches",
  description = "KI-Schulungen und KI-Entwicklung für Coaches, Berater und Dienstleister im DACH-Raum. Dein erster KI-Prozess läuft — in 2 Stunden. Garantiert.",
  hideNav = false,
  path = "",
} = Astro.props;

const siteUrl = "https://valuelift.de";
const canonical = siteUrl + path;
const ogImage = siteUrl + "/og-image.jpg";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Value Lift AI",
  url: "https://valuelift.de",
};

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Marcus Eichler",
  jobTitle: "KI-Berater",
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Consent Mode v2 + Tag Manager.
         Standard: alles verweigert → GA4 sendet nur anonyme, cookielose Signale
         (modellierte Reichweite), bis der Nutzer im Banner zustimmt.
         GTM-ID unten EINMAL eintragen, dann läuft alles. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      window.gtag = gtag;
      gtag("consent", "default", {
        ad_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
        analytics_storage: "denied",
        functionality_storage: "granted",
        security_storage: "granted",
        wait_for_update: 500,
      });
      gtag("set", "url_passthrough", true);
      gtag("set", "ads_data_redaction", true);

      // Einwilligung pro Kategorie (JSON). Version erhöhen, um alle erneut zu fragen.
      // Ablauf abhängig von der Entscheidung:
      //   mind. eine optionale Kategorie zugestimmt -> 6 Monate
      //   alles abgelehnt -> 2 Wochen (eher wieder fragen)
      window.VL_CONSENT_VERSION = 2;
      window.VL_CONSENT_MAXAGE_ACCEPT = 15552000000; // 180 Tage in ms
      window.VL_CONSENT_MAXAGE_REJECT = 1209600000;  // 14 Tage in ms
      window.vlReadConsent = function () {
        try {
          var c = JSON.parse(localStorage.getItem("vl_cookie_consent"));
          if (!c || c.v !== window.VL_CONSENT_VERSION) return null;
          var granted = !!(c.statistik || c.medien);
          var maxAge = granted ? window.VL_CONSENT_MAXAGE_ACCEPT : window.VL_CONSENT_MAXAGE_REJECT;
          if (!c.ts || Date.now() - c.ts > maxAge) return null;
          return c;
        } catch (e) { return null; }
      };

      // Gespeicherte Statistik-Einwilligung anwenden, BEVOR GTM lädt
      try {
        var _vlc = window.vlReadConsent();
        if (_vlc && _vlc.statistik) {
          gtag("consent", "update", { analytics_storage: "granted" });
        }
      } catch (e) {}

      // Container-ID Value Lift AI:
      var GTM_ID = "GTM-5MHHN4KS";
      if (GTM_ID && GTM_ID !== "GTM-XXXXXXX") {
        (function (w, d, s, l, i) {
          w[l] = w[l] || [];
          w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
          var f = d.getElementsByTagName(s)[0],
            j = d.createElement(s),
            dl = l != "dataLayer" ? "&l=" + l : "";
          j.async = true;
          j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
          f.parentNode.insertBefore(j, f);
        })(window, document, "script", "dataLayer", GTM_ID);
      }
    </script>

    <!-- Primäre Meta-Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Value Lift AI" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: self-hosted via @fontsource (kein externer Request, DSGVO-konform) -->

    <!-- Schema.org JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />

    <!-- Tracking: wird nur nach Cookie-Einwilligung geladen (siehe Script unten) -->
  </head>
  <body class="bg-brand-white font-sans text-brand-dark antialiased">

    <!-- Cookie-Consent: Datenschutzeinstellungen (3 Kategorien) -->
    <div id="cookie-scrim"></div>
    <div id="cookie-banner" role="dialog" aria-modal="true" aria-label="Datenschutzeinstellungen">
      <div class="cookie-inner">
        <!-- WP-10: bewusst kein Heading-Element — der Dialog trägt bereits aria-label; so
             beginnt die Content-Hierarchie der Seite sauber mit der Hero-Headline. -->
        <p class="cookie-title">Datenschutzeinstellungen</p>
        <p class="cookie-text">
          Wir verwenden Cookies und Technologien auf unserer Website. Einige sind
          essenziell, andere helfen uns, die Seite und deine Erfahrung zu verbessern.
          Bitte triff eine Auswahl, um fortzufahren. Mehr dazu in unserer
          <a href="/datenschutz">Datenschutzerklärung</a>.
        </p>
        <div class="cookie-cats">
          <label class="cookie-cat">
            <input type="checkbox" checked disabled />
            <span><strong>Essenziell</strong><small>Für den Betrieb der Website notwendig. Immer aktiv.</small></span>
          </label>
          <label class="cookie-cat">
            <input type="checkbox" id="cc-statistik" />
            <span><strong>Statistik</strong><small>Anonyme Reichweitenmessung mit Google Analytics.</small></span>
          </label>
          <label class="cookie-cat">
            <input type="checkbox" id="cc-medien" />
            <span><strong>Externe Medien</strong><small>Lädt den TidyCal-Buchungskalender.</small></span>
          </label>
        </div>
        <div class="cookie-actions">
          <button id="cookie-accept" type="button">Alle akzeptieren</button>
          <button id="cookie-save" type="button">Auswahl speichern</button>
          <button id="cookie-reject" type="button">Ablehnen</button>
        </div>
        <p class="cookie-links">
          <a href="/datenschutz">Datenschutzerklärung</a> · <a href="/impressum">Impressum</a>
        </p>
      </div>
    </div>

    <style>
      #cookie-scrim { position:fixed; inset:0; z-index:9998; background:rgba(0,0,0,.6);
        opacity:0; visibility:hidden; pointer-events:none;
        transition:opacity .3s ease, visibility .3s ease; }
      #cookie-scrim.is-visible { opacity:1; visibility:visible; pointer-events:auto; }
      #cookie-banner { position:fixed; left:50%; top:50%; z-index:9999;
        width:min(34rem, calc(100% - 2rem)); max-height:calc(100vh - 2rem); overflow-y:auto;
        background:#0B1528; color:#fff; padding:1.75rem; border-radius:1rem;
        box-shadow:0 20px 60px rgba(0,0,0,.55);
        opacity:0; visibility:hidden; transform:translate(-50%,-46%) scale(.96);
        transition:transform .35s cubic-bezier(.16,1,.3,1), opacity .35s ease, visibility .35s ease; }
      #cookie-banner.is-visible { opacity:1; visibility:visible; transform:translate(-50%,-50%) scale(1); }
      .cookie-inner { display:flex; flex-direction:column; gap:1rem; }
      .cookie-title { margin:0; font-size:1.15rem; font-weight:800; }
      .cookie-text { margin:0; font-size:.9rem; line-height:1.5; color:#D1D5DB; }
      .cookie-text a, .cookie-links a { color:#F5A623; text-decoration:underline; }
      .cookie-cats { display:flex; flex-direction:column; gap:.5rem; }
      .cookie-cat { display:flex; gap:.6rem; align-items:flex-start; padding:.6rem .75rem;
        background:rgba(255,255,255,.05); border-radius:.5rem; cursor:pointer; }
      .cookie-cat input { margin-top:.15rem; width:1.05rem; height:1.05rem; accent-color:#F5A623; flex-shrink:0; }
      .cookie-cat span { display:flex; flex-direction:column; font-size:.85rem; }
      .cookie-cat small { color:#9CA3AF; font-size:.78rem; margin-top:.1rem; }
      .cookie-actions { display:flex; flex-direction:column; gap:.5rem; }
      .cookie-actions button { width:100%; padding:.7rem 1rem; border-radius:.5rem;
        font-size:.9rem; cursor:pointer; border:none; }
      #cookie-accept { background:#F5A623; color:#0B1528; font-weight:700; }
      #cookie-save { background:rgba(255,255,255,.12); color:#fff; }
      #cookie-reject { background:transparent; color:#fff; border:1px solid rgba(255,255,255,.35); }
      .cookie-links { margin:0; text-align:center; font-size:.78rem; color:#9CA3AF; }
      @media (prefers-reduced-motion: reduce) { #cookie-banner, #cookie-scrim { transition:none; } }
    </style>

    <script is:inline>
      (function () {
        var banner = document.getElementById("cookie-banner");
        var scrim = document.getElementById("cookie-scrim");
        var cbStat = document.getElementById("cc-statistik");
        var cbMed = document.getElementById("cc-medien");
        var VERSION = window.VL_CONSENT_VERSION || 2;

        function lock(){ document.documentElement.style.overflow="hidden"; document.body.style.overflow="hidden"; }
        function unlock(){ document.documentElement.style.overflow=""; document.body.style.overflow=""; }
        function show(){
          var c = window.vlReadConsent ? window.vlReadConsent() : null;
          cbStat.checked = !!(c && c.statistik);
          cbMed.checked = !!(c && c.medien);
          banner.classList.add("is-visible"); scrim.classList.add("is-visible"); lock();
        }
        function hide(){ banner.classList.remove("is-visible"); scrim.classList.remove("is-visible"); unlock(); }

        function apply(statistik, medien){
          if (window.gtag) window.gtag("consent","update",{ analytics_storage: statistik ? "granted" : "denied" });
          try {
            localStorage.setItem("vl_cookie_consent", JSON.stringify({
              v: VERSION, ts: Date.now(), statistik: !!statistik, medien: !!medien
            }));
          } catch(e){}
          window.__vlConsent = { statistik: !!statistik, medien: !!medien };
          loadEmbeds();
        }

        window.vlHasConsent = function(cat){
          var c = window.__vlConsent || (window.vlReadConsent ? window.vlReadConsent() : null);
          return !!(c && c[cat]);
        };

        // Gegatete Einbettungen laden, sobald die passende Kategorie zugestimmt wurde
        function loadEmbeds(){
          var els = document.querySelectorAll(".js-consent-embed");
          for (var k=0; k<els.length; k++){
            var el = els[k];
            if (el.getAttribute("data-loaded")) continue;
            if (!window.vlHasConsent(el.getAttribute("data-category"))) continue;
            var tpl = el.querySelector("template");
            if (!tpl) continue;
            el.innerHTML = "";
            el.appendChild(tpl.content.cloneNode(true));
            var scripts = el.querySelectorAll("script");
            for (var s=0; s<scripts.length; s++){
              var old = scripts[s], ns = document.createElement("script");
              for (var a=0; a<old.attributes.length; a++){ ns.setAttribute(old.attributes[a].name, old.attributes[a].value); }
              ns.text = old.text; old.parentNode.replaceChild(ns, old);
            }
            el.setAttribute("data-loaded","1");
          }
        }
        window.vlLoadEmbeds = loadEmbeds;

        // Klick auf einen "Inhalt laden"-Button im Platzhalter: Externe Medien zustimmen + laden
        document.addEventListener("click", function(ev){
          var btn = ev.target && ev.target.closest ? ev.target.closest(".consent-load-btn") : null;
          if (!btn) return;
          var cur = window.vlReadConsent ? window.vlReadConsent() : null;
          apply(cur ? cur.statistik : false, true);
        });

        document.getElementById("cookie-accept").addEventListener("click", function(){ apply(true, true); hide(); });
        document.getElementById("cookie-save").addEventListener("click", function(){ apply(cbStat.checked, cbMed.checked); hide(); });
        document.getElementById("cookie-reject").addEventListener("click", function(){ apply(false, false); hide(); });

        window.vlOpenCookieSettings = function(){ show(); };

        // Initial: gültige Einwilligung vorhanden? -> anwenden; sonst Modal zeigen
        var stored = window.vlReadConsent ? window.vlReadConsent() : null;
        if (stored){ window.__vlConsent = { statistik: !!stored.statistik, medien: !!stored.medien }; loadEmbeds(); }
        else { show(); }
      })();
    </script>

    {!hideNav && <Header />}

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
