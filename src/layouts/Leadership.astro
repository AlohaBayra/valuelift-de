---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = "In Führung gehen — Leadership Coaching | Marcus Eichler",
  description = "Leadership Coaching für Fach- und Führungskräfte. Marcus Eichler begleitet dich beim nächsten Karriereschritt — mit 29 Jahren Führungserfahrung.",
  path = "",
} = Astro.props;

const siteUrl = "https://valuelift.de";
const canonical = siteUrl + path;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Value Lift — Marcus Eichler" />
  </head>

  <body style="margin: 0; padding: 0; font-family: 'Montserrat', 'Outfit', ui-sans-serif, sans-serif; background: #FFFFFF; color: #0A1628;">

    <!-- Leadership Header — Blau -->
    <header style="background-color: #015FA3; position: sticky; top: 0; z-index: 50; box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
      <nav style="max-width: 72rem; margin: 0 auto; padding: 0.75rem 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.75rem;">

        <!-- Branding — blaues Leadership-Logo -->
        <a href="/leadership" style="text-decoration: none; display: flex; align-items: center; gap: 0.75rem;">
          <img src="/leadership/logo-leadership.png" alt="ValueLift – In Führung gehen" style="height: 2.5rem; width: auto;" />
        </a>

        <!-- Nav -->
        <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
          <a href="/leadership" style="color: rgba(255,255,255,0.85); text-decoration: none; font-size: 0.875rem; font-weight: 600;">Coaching</a>
          <a href="/leadership/angebote" style="color: rgba(255,255,255,0.85); text-decoration: none; font-size: 0.875rem; font-weight: 600;">Angebote</a>
          <a href="/ueber-mich" style="color: rgba(255,255,255,0.85); text-decoration: none; font-size: 0.875rem; font-weight: 600;">Über Marcus</a>
          <a href="/leadership#kontakt"
            style="background-color: #FFFFFF; color: #015FA3; padding: 0.5rem 1.25rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 700; text-decoration: none;">
            Gespräch buchen
          </a>
        </div>

      </nav>

      <!-- Trennlinie zur KI-Welt -->
      <div style="background-color: rgba(255,255,255,0.15); text-align: center; padding: 0.2rem; font-size: 0.75rem; color: rgba(255,255,255,0.7);">
        Auch KI-Prozesse aufbauen? →
        <a href="/" style="color: #FFFFFF; font-weight: 600; text-decoration: none;">Zur KI-Beratung (Value Lift AI)</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Leadership Footer -->
    <footer style="background-color: #0A1628; color: #D1D5DB; padding: 2.5rem 1rem; margin-top: 0;">
      <div style="max-width: 56rem; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 2rem; justify-content: space-between; align-items: flex-start;">
        <div>
          <p style="font-weight: 700; color: #FFFFFF; margin: 0 0 0.25rem;">Marcus Eichler</p>
          <p style="font-size: 0.875rem; margin: 0; color: #9CA3AF;">Leadership Coaching · Value Lift</p>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 1rem; font-size: 0.875rem;">
          <a href="/impressum" style="color: #9CA3AF; text-decoration: none;">Impressum</a>
          <a href="/datenschutz" style="color: #9CA3AF; text-decoration: none;">Datenschutz</a>
          <a href="/agb" style="color: #9CA3AF; text-decoration: none;">AGB</a>
          <a href="https://www.linkedin.com/in/marcus-eichler" target="_blank" rel="noopener" style="color: #9CA3AF; text-decoration: none;">LinkedIn</a>
          <a href="/" style="color: #4A90E2; text-decoration: none; font-weight: 600;">→ KI-Beratung (Value Lift AI)</a>
        </div>
      </div>
      <p style="text-align: center; font-size: 0.8125rem; color: #6B7280; margin-top: 2rem;">© 2026 Marcus Eichler · Value Lift</p>
    </footer>

  </body>
</html>
