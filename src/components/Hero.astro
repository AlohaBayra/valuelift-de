---
export interface Props {
  headline?: string;
  subtext?: string;
}

const {
  headline = "Dein erster KI-Prozess läuft — in 2 Stunden. Garantiert.",
  subtext = "Die meisten scheitern nicht am Wissen. Sie scheitern daran, alleine durch das Chaos zu navigieren. Im KI-Kickstart baust du in 2 Stunden deinen ersten laufenden KI-Prozess — live, mit mir, garantiert.",
} = Astro.props;
---

<section
  class="relative overflow-hidden bg-brand-dark text-brand-white"
  style="background-image: radial-gradient(60% 60% at 70% 0%, rgba(245,166,35,0.12) 0%, rgba(11,21,40,0) 60%), linear-gradient(180deg, #0B1528 0%, #080f1e 100%);"
>
  <div class="relative mx-auto max-w-4xl px-4 py-10 text-center sm:px-6 sm:py-20">
    <!-- Badge-Pill -->
    <span
      class="mb-3 inline-block rounded-full border border-brand-blue bg-brand-blue/10 px-4 py-1 text-sm font-semibold text-brand-blueLight"
    >
      KI-Beratung &amp; KI-Automatisierung für Berater und Coaches
    </span>

    <h1
      class="text-balance text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl md:text-6xl"
    >
      {headline}
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300 sm:text-xl">
      {subtext}
    </p>

    <!-- ST14: Primärer CTA groß, sekundärer CTA als kleiner Textlink darunter -->
    <div class="mt-10 flex flex-col items-center gap-3">
      <a
        href="https://buy.stripe.com/00wfZggVEcLs3DVfhi8bS05"
        target="_blank"
        rel="noopener"
        class="rounded-lg bg-brand-blue px-8 py-4 text-base font-bold text-brand-black shadow-lg transition-transform hover:scale-[1.02] hover:bg-brand-blueLight"
      >
        KI-Kickstart buchen — 97€
      </a>
      <a
        href="/buchen"
        style="font-size: 0.875rem; color: #9CA3AF; text-decoration: none;"
        onmouseover="this.style.color='#F5A623'"
        onmouseout="this.style.color='#9CA3AF'"
      >
        Noch unsicher? Kostenloses Erstgespräch buchen →
      </a>
    </div>

    <!-- ST02: Karriere-Credentials (inline-styles für zuverlässiges Rendering) -->
    <div style="margin-top: 1.5rem; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 0.5rem 0.75rem; font-size: 0.875rem; color: #9CA3AF;">
      <span>29 Jahre Führungserfahrung</span>
      <span style="color: #F5A623;" aria-hidden="true">·</span>
      <span>CEO mit Unternehmensverkauf</span>
      <span style="color: #F5A623;" aria-hidden="true">·</span>
      <span>&gt;1 Mrd. € Impact bei Telefónica</span>
    </div>

  </div>
</section>
