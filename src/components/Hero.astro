---
export interface Props {
  headline?: string;
  subtext?: string;
}

const {
  headline = "Willst du KI in deinem Mandat nutzen — wie ein Operator, nicht wie ein Bastler?",
  subtext = "Ich baue Interim Managern das KI-System, das im Mandat liefert — als Ex-COO, der sein eigenes Geschäft damit führt.",
} = Astro.props;
---

<section class="relative overflow-hidden bg-brand-dark text-brand-white" style="min-height: 540px;">

  <!-- Vollbild-Hintergrund: dein Foto -->
  <div style="position: absolute; inset: 0;">
    <img src="/leadership/hero-bg.png" alt="" aria-hidden="true"
      style="width: 100%; height: 100%; object-fit: cover; object-position: center top;" />
    <!-- Gradient: links stark abgedunkelt für Lesbarkeit, rechts Foto kräftig sichtbar -->
    <div style="position: absolute; inset: 0;
      background: linear-gradient(to right, rgba(11,21,40,0.97) 0%, rgba(11,21,40,0.85) 35%, rgba(11,21,40,0.3) 62%, rgba(11,21,40,0) 100%);"></div>
  </div>

  <!-- Text: linksbündig, max. halbe Breite -->
  <div style="position: relative; z-index: 1; max-width: 72rem; margin: 0 auto; padding: 5rem 1.5rem 4rem;">
    <div style="max-width: 36rem;">

      <!-- Badge: für wen -->
      <span style="display: inline-block; border: 1px solid rgba(245,166,35,0.5); background: rgba(245,166,35,0.08); color: #F5A623; font-size: 0.8125rem; font-weight: 600; padding: 0.3rem 0.875rem; border-radius: 9999px; margin-bottom: 1.25rem;">
        Für Interim Manager
      </span>

      <!-- H1 -->
      <h1 style="font-size: clamp(1.875rem, 4vw, 2.875rem); font-weight: 800; line-height: 1.1; color: #FFFFFF; margin-bottom: 1rem;">
        {headline}
      </h1>

      <!-- Credentials — direkt unter H1 als erster Vertrauensanker -->
      <div style="display: flex; flex-wrap: wrap; gap: 0.35rem 0.6rem; margin-bottom: 1.25rem;">
        <span style="font-size: 0.8125rem; font-weight: 600; color: #F5A623;">Marcus Eichler</span>
        <span style="color: #4B5563; font-size: 0.8125rem;">·</span>
        <span style="font-size: 0.8125rem; color: #9CA3AF;">Ex-COO/CEO mit Exit</span>
        <span style="color: #4B5563; font-size: 0.8125rem;">·</span>
        <span style="font-size: 0.8125rem; color: #9CA3AF;">baut &amp; betreibt sein Geschäft auf 20+ selbstgebauten KI-Agenten</span>
        <span style="color: #4B5563; font-size: 0.8125rem;">·</span>
        <span style="font-size: 0.8125rem; color: #9CA3AF;">KI/ML seit 2004</span>
      </div>

      <!-- Subtext -->
      <p style="font-size: 1rem; color: #D1D5DB; line-height: 1.7; margin-bottom: 2rem;">
        {subtext}
      </p>

      <!-- CTA (genau 1 → /buchen) -->
      <div style="display: flex; flex-direction: column; align-items: flex-start; gap: 0.625rem;">
        <a
          href="/buchen"
          style="display: inline-block; background: #F5A623; color: #0B1528; font-weight: 700; font-size: 1rem; padding: 0.9rem 2rem; border-radius: 0.5rem; text-decoration: none;"
        >
          Erstgespräch vereinbaren
        </a>
        <p style="font-size: 0.75rem; color: #6B7280; margin: 0;">
          20 Minuten, kostenlos. Wir schauen auf deine Pipeline — du entscheidest danach.
        </p>
      </div>

    </div>
  </div>
</section>
