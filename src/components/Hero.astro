---
export interface Props {
  headline?: string;
  subtext?: string;
}

const {
  headline = "Dein erster KI-Prozess läuft — in 2 Stunden. Garantiert.",
  subtext = "Die meisten scheitern nicht am Wissen. Sie scheitern daran, dass sie alleine starten. Ich bin Marcus — ich baue KI-Prozesse für Berater und Coaches, und begleite dich dabei.",
} = Astro.props;
---

<section
  class="relative overflow-hidden bg-brand-dark text-brand-white"
  style="background-image: radial-gradient(60% 60% at 70% 0%, rgba(245,166,35,0.12) 0%, rgba(11,21,40,0) 60%), linear-gradient(180deg, #0B1528 0%, #080f1e 100%);"
>
  <div class="relative mx-auto max-w-4xl px-4 py-10 text-center sm:px-6 sm:py-20">
    <!-- Badge-Pill -->
    <span
      class="mb-3 inline-block rounded-full border border-brand-blue bg-brand-blue/10 px-4 py-1 text-sm font-semibold text-brand-blueLight"
    >
      KI-Beratung &amp; KI-Automatisierung für Berater und Coaches
    </span>

    <h1
      class="text-balance text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl md:text-6xl"
    >
      {headline}
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300 sm:text-xl">
      {subtext}
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="https://buy.stripe.com/00wfZggVEcLs3DVfhi8bS05"
        target="_blank"
        rel="noopener"
        class="w-full rounded-lg bg-brand-blue px-8 py-4 text-base font-bold text-brand-black shadow-lg transition-transform hover:scale-[1.02] hover:bg-brand-blueLight sm:w-auto"
      >
        KI-Kickstart buchen — 97€
      </a>
      <a
        href="/buchen"
        class="text-base font-semibold text-brand-white underline-offset-4 hover:text-brand-blueLight hover:underline"
      >
        Kostenloses Erstgespräch buchen →
      </a>
    </div>

    <!-- M05: Karriere-Credentials -->
    <div class="mt-6 flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-sm text-gray-400">
      <span>29 Jahre Führungserfahrung</span>
      <span class="text-brand-blue" aria-hidden="true">·</span>
      <span>CEO mit Unternehmensverkauf</span>
      <span class="text-brand-blue" aria-hidden="true">·</span>
      <span>&gt;1 Mrd. € Impact bei Telefónica</span>
    </div>

  </div>
</section>
