---
export interface Props {
  headline?: string;
  subtext?: string;
}

const {
  headline = "Dein erster KI-Prozess läuft — nach 2 Stunden. Oder du zahlst nichts.",
  subtext = "Die meisten scheitern nicht am Wissen. Sie scheitern daran, alleine durch das Chaos zu navigieren. Im KI-Kickstart baust du in 2 Stunden deinen ersten laufenden KI-Prozess — live, mit mir.",
} = Astro.props;
---

<section class="relative overflow-hidden bg-brand-dark text-brand-white">
  <div style="max-width: 72rem; margin: 0 auto; display: flex; min-height: 540px;">

    <!-- Linke Spalte: Text, linksbündig -->
    <div style="flex: 1.3; min-width: 280px; padding: 4rem 2.5rem 4rem 1.5rem; display: flex; flex-direction: column; justify-content: center; background: #0B1528;">

      <!-- Badge -->
      <span style="display: inline-block; border: 1px solid rgba(245,166,35,0.5); background: rgba(245,166,35,0.08); color: #F5A623; font-size: 0.8125rem; font-weight: 600; padding: 0.3rem 0.875rem; border-radius: 9999px; margin-bottom: 1.25rem; width: fit-content;">
        KI-Beratung &amp; KI-Automatisierung für Berater und Coaches
      </span>

      <!-- H1 -->
      <h1 style="font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; line-height: 1.1; color: #FFFFFF; margin-bottom: 1rem;">
        {headline}
      </h1>

      <!-- Credentials — nach oben verschoben (Vertrauensanker vor dem Subtext) -->
      <div style="display: flex; flex-wrap: wrap; gap: 0.4rem 0.6rem; margin-bottom: 1.25rem;">
        <span style="font-size: 0.8125rem; font-weight: 600; color: #F5A623;">Marcus Eichler</span>
        <span style="color: #4B5563; font-size: 0.8125rem;">·</span>
        <span style="font-size: 0.8125rem; color: #9CA3AF;">29 Jahre Führung</span>
        <span style="color: #4B5563; font-size: 0.8125rem;">·</span>
        <span style="font-size: 0.8125rem; color: #9CA3AF;">Ex-CEO mit Unternehmensverkauf</span>
        <span style="color: #4B5563; font-size: 0.8125rem;">·</span>
        <span style="font-size: 0.8125rem; color: #9CA3AF;">&gt;1 Mrd. € Impact bei Telefónica</span>
      </div>

      <!-- Subtext -->
      <p style="font-size: 1rem; color: #D1D5DB; line-height: 1.7; margin-bottom: 2rem; max-width: 32rem;">
        {subtext}
      </p>

      <!-- CTAs -->
      <div style="display: flex; flex-direction: column; align-items: flex-start; gap: 0.625rem;">
        <a
          href="https://buy.stripe.com/00wfZggVEcLs3DVfhi8bS05"
          target="_blank"
          rel="noopener"
          style="display: inline-block; background: #F5A623; color: #0B1528; font-weight: 700; font-size: 1rem; padding: 0.9rem 2rem; border-radius: 0.5rem; text-decoration: none;"
        >
          KI-Kickstart buchen — 97€
        </a>

        <!-- Microcopy unter primärem CTA -->
        <p style="font-size: 0.75rem; color: #6B7280; margin: 0;">
          Läuft nichts nach 2 Stunden → du zahlst nichts. Garantiert.
        </p>

        <!-- Sekundärer CTA — neu formuliert -->
        <a
          href="/buchen"
          style="font-size: 0.875rem; color: #9CA3AF; text-decoration: none; margin-top: 0.25rem;"
          onmouseover="this.style.color='#F5A623'"
          onmouseout="this.style.color='#9CA3AF'"
        >
          Lieber erst sprechen? 20 Minuten, kostenlos, ohne Pitch →
        </a>
      </div>

    </div>

    <!-- Rechte Spalte: Foto klar sichtbar, kein Text-Overlay -->
    <div style="flex: 1; min-width: 260px; position: relative; overflow: hidden; display: none;"
      class="hero-photo-col">
      <img
        src="/leadership/marcus-about.jpeg"
        alt="Marcus Eichler — KI-Architekt"
        style="width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block;"
      />
      <!-- Weicher Übergang zur linken Spalte -->
      <div style="position: absolute; top: 0; left: 0; width: 30%; height: 100%;
        background: linear-gradient(to right, #0B1528, transparent);"></div>
    </div>

  </div>
</section>

<style>
  @media (min-width: 640px) {
    .hero-photo-col {
      display: block !important;
    }
  }
</style>
