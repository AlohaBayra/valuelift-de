---
// UM-04 — IM-Value-Ladder (Modell B). Segmentierung nach Mandatsphase, KEIN öffentlicher Preis,
// kein Stripe, kein Euro-Betrag im DOM (QA-Grep). Drei Stufen → /kickstart · /werkstatt · /buchen.
const offers = [
  {
    name: "Mandats-Kickstart",
    fuer: "Im oder vor dem laufenden Mandat",
    format: "Fester Lieferrahmen · in Tagen",
    contents: [
      "KI-Werkzeuge auf deiner eigenen Seite — im Mandat sofort einsatzbereit",
      "Reporting-Automation, Analyse-Vorlagen, Stakeholder-Map, Wirkungs-Doku",
      "Gebaut auf meiner Seite, nie in deinem Kundensystem",
      "Du besitzt es danach — kein Abo, kein Vendor-Lock-in",
    ],
    guarantee: "Lauf-Garantie: läuft es nicht wie aufgebaut, arbeite ich kostenlos nach.",
    ctaLabel: "Mandats-Kickstart ansehen",
    ctaHref: "/kickstart",
    style: "solid",
    featured: true,
  },
  {
    name: "Werkstatt: Interim-Magnet",
    fuer: "Zwischen Mandaten / Mandat läuft aus",
    format: "8 Wochen · async · begleitet",
    contents: [
      "Du baust dir deinen Akquise-Magneten selbst — begleitet",
      "Wirkungs-Maschine + Pipeline-Wärmer mit Mandatsend-Trigger",
      "Im eigenen Takt, Mandats-Pause jederzeit möglich",
      "Damit das nächste Mandat anläuft, bevor das aktuelle endet",
    ],
    guarantee: "Lauf-Garantie auf deine zwei Herzstück-Maschinen.",
    ctaLabel: "Zur Werkstatt",
    ctaHref: "/werkstatt",
    style: "outline",
    featured: false,
  },
  {
    name: "Interims-Magnet App (zum Kurs)",
    fuer: "Für Kickstart- & Werkstatt-Teilnehmer",
    format: "Zugabe zum Kurs · 6 Monate inklusive, danach monatlich",
    contents: [
      "Deine Sichtbarkeits- & Pipeline-Maschine läuft weiter — die App unterstützt dich beim Betrieb deines selbst gebauten Systems.",
      "Erste 6 Monate zum Kurs inklusive, danach monatliches Abo.",
      "Kein Standalone-Done-for-you — ein Add-on, das deinen laufenden Betrieb trägt.",
    ],
    guarantee: "Lauf-Garantie: läuft es nicht wie aufgebaut, arbeite ich kostenlos nach.",
    note: "Keine Zeit? Auf Anfrage baue ich es dir als Premium.",
    ctaLabel: "Erstgespräch buchen",
    ctaHref: "/buchen",
    style: "outline",
    featured: false,
  },
];
---

<section class="bg-brand-lightBg py-16 sm:py-24" id="angebote">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
        Drei Wege — je nach Mandatsphase
      </h2>
      <p class="mt-4 text-lg text-brand-gray">
        Welcher Weg zu dir passt, hängt davon ab, wo du gerade im Mandatszyklus
        stehst — nie vom Budget. Den Rahmen klären wir im Erstgespräch.
      </p>
    </div>

    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {
        offers.map((offer) => (
          <article
            class:list={[
              "relative flex flex-col rounded-2xl border bg-brand-white p-8 shadow-sm transition-shadow hover:shadow-lg",
              offer.featured ? "border-brand-blue ring-2 ring-brand-blue" : "border-gray-200",
            ]}
          >
            {offer.featured && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-blue px-3 py-1 text-xs font-bold text-brand-black">
                Im Mandat
              </span>
            )}

            <h3 class="text-2xl font-bold">{offer.name}</h3>

            <p class="mt-3 text-sm font-semibold text-brand-blue">{offer.fuer}</p>
            <p class="mt-1 text-sm font-semibold text-brand-gray">{offer.format}</p>

            <ul class="mt-6 flex-1 space-y-3 text-base">
              {offer.contents.map((item) => (
                <li class="flex items-start gap-2">
                  <span class="mt-0.5 font-bold text-brand-blue" aria-hidden="true">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <p class="mt-6 rounded-lg bg-brand-lightBg p-3 text-sm font-semibold text-brand-dark">
              <span aria-hidden="true">🛡️</span> Garantie: {offer.guarantee}
            </p>

            <a
              href={offer.ctaHref}
              class:list={[
                "mt-6 block rounded-lg px-4 py-3 text-center text-base font-bold transition-colors",
                offer.style === "solid"
                  ? "bg-brand-blue text-brand-black hover:bg-brand-blueLight"
                  : "border-2 border-brand-blue text-brand-blue hover:bg-brand-blue hover:text-brand-black",
              ]}
            >
              {offer.ctaLabel}
            </a>

            {offer.note && (
              <p class="mt-3 text-center text-xs italic text-brand-gray">{offer.note}</p>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
